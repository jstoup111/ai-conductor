# Project-local state (generated per target project, not part of harness).
# The conductor runs inside src/conductor/ and writes these there; the patterns
# are unanchored so they also match the nested src/conductor/.daemon/ etc.
.pipeline/
.memory/
.memory*.bak/
.daemon/
.worktrees/

# Node / TypeScript conductor build artifacts
node_modules/
src/conductor/dist
src/conductor/dist-versions/
# publish-engine stages the built engine into a `.engine-staging-<rand>/` temp dir
# and renames it into place; an interrupted/crashed publish orphans one. Unignored,
# that orphan dirties the tree and the daemon then permanently skips fast-forward.
.engine-staging-*/

# OS
.DS_Store
Thumbs.db

# Editor
*.swp
*.swo
*~
.vscode/
.idea/

# Tool-local / session state (regenerated locally, not part of the harness)
.serena/
.handoffs/

# Local environment (daemon per-worktree namespace, secrets)
.env
