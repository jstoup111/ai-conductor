# =============================================================================
# SHARED INFRASTRUCTURE — one instance, all worktrees connect to it
# =============================================================================
# Start shared services once: docker compose up -d
# Every worktree connects to these same services with different namespaces.

{{DB_ENGINE}}_HOST=localhost
{{DB_ENGINE}}_PORT={{DB_DEFAULT_PORT}}
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# WORKTREE-SPECIFIC OVERRIDES — each worktree gets unique values
# =============================================================================
# Override in .env.local (gitignored) to avoid collisions between worktrees.
# Main worktree uses these defaults. Feature worktrees set their own values.

WORKTREE_DB_SUFFIX=
REDIS_NAMESPACE=default
PORT={{APP_DEFAULT_PORT}}

# =============================================================================
# APPLICATION
# =============================================================================

{{FRAMEWORK_ENV_VAR}}=development
SECRET_KEY_BASE=replace_me_with_a_real_secret
