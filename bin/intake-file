#!/usr/bin/env bash
set -euo pipefail

# intake-file — one atomic filing of a criteria-complete intake issue.
#
# Delegates to fileIntakeIssue (src/conductor/src/intake-file-cli.ts →
# src/engine/engineer/intake/file-issue.ts): creates the GitHub issue,
# resolves size/priority (given ▸ prompt-on-TTY ▸ infer ▸ default), applies
# the priority:/size: labels, and records --depends-on blocked_by link(s).
# Label/depends-on failures after a successful create are warnings (exit 0);
# only a failed issue create is fatal.
#
# Usage:
#   bin/intake-file --title <t> --body <b> [--size S|M|L] \
#     [--priority critical|high|medium|low] [--depends-on owner/repo#N ...] [--repo owner/repo]

HARNESS_DIR="$(cd "$(dirname "$0")/.." && pwd)"
CONDUCTOR_DIR="${HARNESS_DIR}/src/conductor"

cd "$CONDUCTOR_DIR"
exec npx tsx "${CONDUCTOR_DIR}/src/intake-file-cli.ts" "$@"
