#!/usr/bin/env bash
set -euo pipefail

# conduct — Drives a feature through the full SDLC harness.
#
# Uses a persistent Claude session (Ralph-style loop):
#   - Single session ID maintained across all steps
#   - --resume to continue context between invocations
#   - --output-format stream-json for real-time output parsing
#   - Interactive recovery on failure (retry, skip, manual fix, quit)
#
# Usage:
#   conduct "Build a URL shortener API"
#   conduct --resume
#   conduct --status
#   conduct --step bootstrap
#   conduct --from plan

HARNESS_DIR="$(cd "$(dirname "$0")/.." && pwd)"
ORIGINAL_CWD="$(pwd)"
ORIGINAL_ARGS=("$@")
PROJECT_DIR="$(pwd)"
PIPELINE_DIR="${PROJECT_DIR}/.pipeline"
SESSION_LOG="${PIPELINE_DIR}/conduct.log"
STATE_FILE="${PIPELINE_DIR}/conduct-state.json"
SESSION_FILE="${PIPELINE_DIR}/conduct-session-id"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'
BOLD='\033[1m'

# ─── Helpers ──────────────────────────────────────────────────────────────────

log()  { echo -e "${BLUE}[conduct]${NC} $*"; }
ok()   { echo -e "${GREEN}  ✓${NC} $*"; }
fail() { echo -e "${RED}  ✗${NC} $*"; }
warn() { echo -e "${YELLOW}  ⚠${NC} $*"; }

CURRENT_STEP_FILE="${PIPELINE_DIR}/.current-step"
STEP_START_FILE="${PIPELINE_DIR}/.step-start-time"

set_current_step() {
  ensure_pipeline_dir
  echo "$1" > "$CURRENT_STEP_FILE" 2>/dev/null
  date +%s > "$STEP_START_FILE" 2>/dev/null
}

get_current_step() {
  cat "$CURRENT_STEP_FILE" 2>/dev/null || echo ""
}

# Elapsed time since step started, formatted as Xm Ys
get_step_elapsed() {
  local start
  start=$(cat "$STEP_START_FILE" 2>/dev/null || echo "0")
  [ "$start" = "0" ] && return
  local now elapsed mins secs
  now=$(date +%s)
  elapsed=$((now - start))
  mins=$((elapsed / 60))
  secs=$((elapsed % 60))
  if [ "$mins" -gt 0 ]; then
    echo "${mins}m ${secs}s"
  else
    echo "${secs}s"
  fi
}

step_header() {
  local num=$1 name=$2 phase=$3
  set_current_step "$name"
}

ensure_pipeline_dir() {
  mkdir -p "${PIPELINE_DIR}"
}

# ─── Artifact Review ─────────────────────────────────────────────────────────

# Render a markdown file in the terminal using the best available tool
render_md() {
  local file=$1
  if command -v glow &>/dev/null; then
    glow -w 80 "$file"
  elif command -v bat &>/dev/null; then
    bat --style=plain --language=md "$file"
  elif command -v batcat &>/dev/null; then
    batcat --style=plain --language=md "$file"
  elif [ -t 1 ] && command -v less &>/dev/null; then
    # Fallback: cat with line numbers, paged for readability
    cat -n "$file" | less -R -F -X
  else
    cat "$file"
  fi
}

# Review one or more artifacts with approve/reject per file.
# Usage: review_artifacts "step_name" file1 [file2 ...]
# Returns 0 if all approved, 1 if any rejected.
review_artifacts() {
  local step_name=$1; shift
  local files=("$@")
  local total=${#files[@]}
  local i=0

  # Skip review in auto mode
  if [ "${RUN_MODE}" = "auto" ]; then
    log "Auto mode — accepting ${total} artifact(s) for ${step_name}"
    return 0
  fi

  # Pause live refresh so it doesn't overwrite the review display.
  # Full stop + terminal reset to prevent ANSI escape collisions (WSL2 safe).
  stop_live_refresh
  tput sgr0 2>/dev/null || true

  for file in "${files[@]}"; do
    i=$((i + 1))
    echo ""
    echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "  ${BOLD}[${i}/${total}] ${step_name}: $(basename "$file")${NC}"
    echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
    render_md "$file"
    echo ""
    echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"

    if [ -t 0 ]; then
      read -r -p "  [enter=approve / r=reject / s=skip remaining]: " verdict
      case "$verdict" in
        [rR]) warn "Rejected: $(basename "$file")"; start_live_refresh 10; return 1 ;;
        [sS]) log "Skipping review of remaining artifacts"; start_live_refresh 10; return 0 ;;
        *)    ok "Approved: $(basename "$file")" ;;
      esac
    fi
  done

  start_live_refresh 10
  return 0
}

# ─── Session Management ──────────────────────────────────────────────────────

get_session_id() {
  if [ -f "$SESSION_FILE" ]; then
    cat "$SESSION_FILE"
  else
    local sid
    sid=$(python3 -c "import uuid; print(uuid.uuid4())")
    echo "$sid" > "$SESSION_FILE"
    echo "$sid"
  fi
}

# Reset session when Claude reports the session ID is stale/expired
reset_session() {
  warn "Session expired — starting fresh"
  rm -f "$SESSION_FILE" "${PIPELINE_DIR}/session-created"
  get_session_id > /dev/null
}

# Name the session after brainstorm so it's identifiable in /resume and remote-control
name_session() {
  local session_id
  session_id=$(get_session_id)
  local project_name
  project_name=$(basename "$PROJECT_DIR")
  # Build a short descriptive name: project + feature summary (first 40 chars)
  local feature_short="${FEATURE_DESC:0:40}"
  local session_name="${project_name}: ${feature_short}"
  # Resume with --name to set the display name, then immediately exit with a no-op prompt
  claude --resume "$session_id" --name "$session_name" -p "Session named." --dangerously-skip-permissions >> "$SESSION_LOG" 2>&1 || {
    warn "Could not name session (session may have expired)"
  }
  log "Session named: ${session_name}"
}

# ─── State Management ────────────────────────────────────────────────────────

save_state() {
  local step=$1 status=$2
  ensure_pipeline_dir
  # Clear current step indicator when a step completes
  if [ "$status" = "done" ] || [ "$status" = "skipped" ] || [ "$status" = "failed" ]; then
    echo "" > "$CURRENT_STEP_FILE" 2>/dev/null
  fi
  python3 << PYEOF
import json, os
path = "$STATE_FILE"
state = {}
if os.path.exists(path):
    with open(path) as f:
        state = json.load(f)
state["$step"] = "$status"
state["last_step"] = "$step"
with open(path, "w") as f:
    json.dump(state, f, indent=2)
PYEOF
}

get_state() {
  local step=$1
  if [ -f "$STATE_FILE" ]; then
    python3 -c "
import json
with open('$STATE_FILE') as f:
    state = json.load(f)
print(state.get('$step', 'pending'))
"
  else
    echo "pending"
  fi
}

# Check if a step is recorded as done/skipped in the state file.
# Per-feature steps use this as the primary "already complete" check
# because artifact files from prior features may be inherited by the worktree.
step_done() {
  local step=$1
  local s
  s=$(get_state "$step")
  [ "$s" = "done" ] || [ "$s" = "skipped" ]
}

# ─── Claude Invocation ────────────────────────────────────────────────────────

run_claude() {
  local prompt=$1
  local mode=${2:-print}  # "print" or "interactive"
  local session_id
  session_id=$(get_session_id)

  ensure_pipeline_dir

  # First successful call uses --session-id (creates session).
  # Subsequent calls use --resume (continues session).
  # The marker file is only created AFTER a successful call.
  local session_flag
  if [ -f "${PIPELINE_DIR}/session-created" ]; then
    session_flag="--resume ${session_id}"
  else
    session_flag="--session-id ${session_id}"
  fi

  # Build loop context
  local iteration
  iteration=$(python3 -c "
import json, os
path = '$STATE_FILE'
skip_keys = {'last_step', 'feature_desc', 'complexity_tier'}
if os.path.exists(path):
    with open(path) as f:
        state = json.load(f)
    done = sum(1 for k, v in state.items() if k not in skip_keys and isinstance(v, str) and v in ('done', 'skipped'))
    print(done)
else:
    print(0)
")
  local context="[Conduct step ${iteration}/13] Feature: ${FEATURE_DESC:-unknown}"

  if [ "$mode" = "print" ]; then
    log "Sending to Claude (session: ${session_id:0:8}...)..."

    # Clear any stale rate limit marker
    rm -f "${PIPELINE_DIR}/rate-limit-hit"

    local perm_flag="--dangerously-skip-permissions"

    if [ "${VIEW_MODE}" = "output" ]; then
      claude -p "$prompt" \
        $session_flag \
        --append-system-prompt "$context" \
        $perm_flag \
        2>&1 | tee -a "$SESSION_LOG"
    else
      claude -p "$prompt" \
        $session_flag \
        --append-system-prompt "$context" \
        $perm_flag \
        >> "$SESSION_LOG" 2>&1 || true
    fi

    # Check for rate limit via hook marker (StopFailure hook writes this)
    if [ -f "${PIPELINE_DIR}/rate-limit-hit" ]; then
      rm -f "${PIPELINE_DIR}/rate-limit-hit"
      handle_rate_limit
      # Retry after wait
      if [ "${VIEW_MODE}" = "output" ]; then
        claude -p "$prompt" \
          $session_flag \
          --append-system-prompt "$context" \
          $perm_flag \
          2>&1 | tee -a "$SESSION_LOG"
      else
        claude -p "$prompt" \
          $session_flag \
          --append-system-prompt "$context" \
          $perm_flag \
          >> "$SESSION_LOG" 2>&1 || true
      fi
    fi

    # Detect stale session and retry with fresh ID
    if tail -5 "$SESSION_LOG" 2>/dev/null | grep -qi "No conversation found"; then
      reset_session
      session_id=$(get_session_id)
      session_flag="--session-id ${session_id}"
      if [ "${VIEW_MODE}" = "output" ]; then
        claude -p "$prompt" \
          $session_flag \
          --append-system-prompt "$context" \
          $perm_flag \
          2>&1 | tee -a "$SESSION_LOG"
      else
        claude -p "$prompt" \
          $session_flag \
          --append-system-prompt "$context" \
          $perm_flag \
          >> "$SESSION_LOG" 2>&1 || true
      fi
    fi

    touch "${PIPELINE_DIR}/session-created"
    append_progress "$prompt"
  else
    stop_live_refresh
    sleep 0.2 2>/dev/null || true  # let any in-flight refresh flush
    clear
    local step_name
    step_name=$(get_current_step)
    echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "  ${BOLD}Interactive session${NC} — ${step_name}"
    echo -e "  Type ${BOLD}/quit${NC} when done to return to conductor"
    echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
    STATUS_LINES=0
    # Reuse the feature session — context stays lean because each step's
    # system prompt scopes behavior. No fresh sessions needed.
    local step_context="You are running step: ${step_name}. Complete ONLY this step, then stop and let the user /quit to return to the conductor. Do NOT proceed to subsequent steps. ${context}."
    claude $session_flag \
      --append-system-prompt "$step_context" \
      "$prompt" || true
    clear
    reset_display
    start_live_refresh 10
    touch "${PIPELINE_DIR}/session-created"
    append_progress "$prompt"
  fi

  # Rate limit prevention: cooldown between steps + escalation on heavy sessions
  CLAUDE_CALL_COUNT=$((CLAUDE_CALL_COUNT + 1))
  local effective_cooldown=$STEP_COOLDOWN
  if [ "$CLAUDE_CALL_COUNT" -ge 20 ]; then
    effective_cooldown=$((STEP_COOLDOWN_ORIG * 3))
  elif [ "$CLAUDE_CALL_COUNT" -ge 10 ]; then
    effective_cooldown=$((STEP_COOLDOWN_ORIG * 2))
  fi
  if [ "$effective_cooldown" -ne "$STEP_COOLDOWN" ]; then
    STEP_COOLDOWN=$effective_cooldown
    warn "Escalating cooldown to ${STEP_COOLDOWN}s (${CLAUDE_CALL_COUNT} calls this session)"
  fi
  if [ "$effective_cooldown" -gt 0 ]; then
    sleep "$effective_cooldown"
  fi
}

# ─── Artifact Checks ─────────────────────────────────────────────────────────

# Check if any files matching a glob exist.
# The state file (conduct-state.json) tracks per-step completion.
# Artifact checks only need to verify files are present, not timestamp them.
has_artifacts() {
  local pattern=$1
  compgen -G "$pattern" > /dev/null 2>&1
}

check_bootstrap() {
  # Bootstrap artifacts are project-level (committed to git, inherited by worktrees).
  # Existence check only — no timestamp check.
  [ -d "${PROJECT_DIR}/.memory" ] && \
  [ -d "${PROJECT_DIR}/.docs/specs" ] && \
  [ -d "${PROJECT_DIR}/.docs/stories" ] && \
  [ -d "${PROJECT_DIR}/.docs/plans" ]
}

check_assess() {
  # Assessment is project-level. Existence check only.
  compgen -G "${PROJECT_DIR}/.docs/decisions/technical-assessment-*.md" > /dev/null 2>&1
}

check_brainstorm() {
  has_artifacts "${PROJECT_DIR}/.docs/specs/*.md"
}

check_stories() {
  has_artifacts "${PROJECT_DIR}/.docs/stories/*.md" || return 1
  # DRAFT stories don't count as complete
  if grep -rl "Status: DRAFT" "${PROJECT_DIR}/.docs/stories/" > /dev/null 2>&1; then
    return 1
  fi
  return 0
}

check_conflict_check() {
  has_artifacts "${PROJECT_DIR}/.docs/conflicts/*.md"
}

check_plan() {
  has_artifacts "${PROJECT_DIR}/.docs/plans/*.md"
}

check_architecture_review() {
  has_artifacts "${PROJECT_DIR}/.docs/decisions/architecture-review-*.md"
}

check_acceptance_specs() {
  # Check common test locations across stacks
  has_artifacts "${PROJECT_DIR}/spec/integration/*_spec.rb" || \
  has_artifacts "${PROJECT_DIR}/spec/system/*_spec.rb" || \
  has_artifacts "${PROJECT_DIR}/tests/integration/test_*.py" || \
  has_artifacts "${PROJECT_DIR}/tests/acceptance/test_*.py" || \
  has_artifacts "${PROJECT_DIR}/spec/integration/*.py" || \
  has_artifacts "${PROJECT_DIR}/spec/acceptance/*.py" || \
  has_artifacts "${PROJECT_DIR}/tests/**/test_*_acceptance.py" || \
  has_artifacts "${PROJECT_DIR}/test/integration/*.test.*" || \
  has_artifacts "${PROJECT_DIR}/tests/e2e/*.py"
}

check_build() {
  # Pipeline must exist with at least 1 completed task
  if [ -f "${PROJECT_DIR}/.pipeline/task-status.json" ]; then
    local result
    result=$(python3 -c "
import json
with open('${PROJECT_DIR}/.pipeline/task-status.json') as f:
    state = json.load(f)
total = sum(1 for v in state.values() if isinstance(v, dict))
completed = sum(1 for v in state.values() if isinstance(v, dict) and v.get('status') == 'completed')
pending = total - completed
if total == 0:
    print('empty')
elif pending == 0:
    print('done')
else:
    print('pending')
" 2>/dev/null || echo "pending")
    [ "$result" = "done" ] && return 0
  fi
  # Fallback: check log for passing tests (must have >0 examples)
  if [ -f "$SESSION_LOG" ]; then
    # Match "N examples, 0 failures" where N > 0
    grep -qE "[1-9][0-9]* examples?, 0 failures" "$SESSION_LOG" 2>/dev/null && return 0
  fi
  return 1
}

check_manual_test() {
  local results="${PROJECT_DIR}/.docs/manual-test-results.md"
  [ -f "$results" ] || return 1
  # Fail if any FAIL results remain
  if grep -qi "| FAIL" "$results" 2>/dev/null; then
    return 1
  fi
  return 0
}

check_retro() {
  compgen -G "${PROJECT_DIR}/.docs/retros/*.md" > /dev/null 2>&1
}

# ─── Step Definitions ─────────────────────────────────────────────────────────

run_bootstrap() {
  step_header 1 "bootstrap" "UNDERSTAND"
  if check_bootstrap; then
    ok "Already complete"; save_state "bootstrap" "done"; return 0
  fi

  # Bootstrap is split into focused sub-steps. Each gets a FRESH Claude session
  # (claude -p) to avoid context accumulation on large projects.
  # Handoff between steps is via file artifacts, not session context.

  local bs_state

  # Sub-step 1: Detect stack + scaffold directories
  bs_state=$(get_state "bootstrap_detect")
  if [ "$bs_state" != "done" ]; then
    log "Step 1/6: Detecting project stack and scaffolding directories..."
    claude -p "Run /bootstrap Steps 1-3c ONLY. Detect project type and tech stack. Create directories (.memory/, .docs/, .pipeline/, .worktrees/) if missing. Generate .claudeignore from templates/claudeignore.template. Generate PR template from templates/pull_request_template.md to .github/pull_request_template.md (if not present). Load tech-context if matched.

Add to .gitignore (idempotent): .pipeline/ and .worktrees/

If this is an empty directory, scaffold the project first (ask what framework).
Do NOT analyze existing code, draft stories, or generate CLAUDE.md yet.
Write detection results to .pipeline/bootstrap-detection.json: {framework, database, test_framework, frontend, tech_context}" \
      --dangerously-skip-permissions >> "$SESSION_LOG" 2>&1 || true
    save_state "bootstrap_detect" "done"
  fi

  # Sub-step 2: Inventory existing code (existing projects only)
  bs_state=$(get_state "bootstrap_inventory")
  if [ "$bs_state" != "done" ]; then
    if [ -d "${PROJECT_DIR}/app" ] || [ -d "${PROJECT_DIR}/src" ] || [ -f "${PROJECT_DIR}/main.py" ]; then
      log "Step 2/6: Scanning existing codebase..."
      claude -p "Run /bootstrap Step 4 ONLY. Analyze the existing code:
- List models, controllers, services, jobs
- Count source files and test files
- Check test coverage (which files have specs, which don't)
- Check git history: git log --oneline -20, open PRs
- List any existing plan files in .docs/plans/ (note their names and phases)

Write inventory summary to .pipeline/bootstrap-inventory.md. Keep concise — later steps read this file instead of re-scanning the codebase." \
        --dangerously-skip-permissions >> "$SESSION_LOG" 2>&1 || true
    else
      log "Step 2/6: Fresh project — skipping inventory"
    fi
    save_state "bootstrap_inventory" "done"
  fi

  # Sub-step 3: Draft as-built stories (existing projects only)
  # Reads plans FIRST (richer source), inventory SECOND (gap filler)
  bs_state=$(get_state "bootstrap_stories")
  if [ "$bs_state" != "done" ]; then
    local has_plans=false
    compgen -G "${PROJECT_DIR}/.docs/plans/*.md" > /dev/null 2>&1 && has_plans=true

    if $has_plans || [ -f "${PROJECT_DIR}/.pipeline/bootstrap-inventory.md" ]; then
      log "Step 3/6: Drafting as-built stories..."

      local story_prompt="Run /bootstrap Step 4b ONLY. Draft as-built stories to .docs/stories/ with Status: DRAFT and [AS-BUILT] markers."

      if $has_plans; then
        # Plans exist — multiple agents, one per plan file
        local plan_count
        plan_count=$(compgen -G "${PROJECT_DIR}/.docs/plans/*.md" | wc -l)
        log "  Found ${plan_count} plan files — deriving stories from plans"

        story_prompt="Run /bootstrap Step 4b ONLY. Read .docs/plans/*.md FIRST — derive stories from existing plans. Each plan phase becomes a story group with acceptance criteria based on the plan's tasks.

PRIORITY ORDER:
1. .docs/plans/*.md — primary source (intended behavior)
2. .pipeline/bootstrap-inventory.md — supplement with test coverage gaps and untested files

Draft stories to .docs/stories/ with Status: DRAFT and [AS-BUILT] markers. One story per plan phase or major feature area. Happy paths from plan tasks, negative paths as TODO."
      fi

      claude -p "$story_prompt" \
        --dangerously-skip-permissions >> "$SESSION_LOG" 2>&1 || true
    else
      log "Step 3/6: No plans or inventory — skipping stories"
    fi
    save_state "bootstrap_stories" "done"
  fi

  # Sub-step 4: Document architectural decisions as ADRs (existing projects only)
  bs_state=$(get_state "bootstrap_adrs")
  if [ "$bs_state" != "done" ]; then
    if [ -f "${PROJECT_DIR}/.pipeline/bootstrap-inventory.md" ]; then
      log "Step 4/6: Documenting architectural decisions..."
      claude -p "Run /bootstrap Step 4c ONLY. Read .pipeline/bootstrap-inventory.md and .pipeline/bootstrap-detection.json. Create ADRs in .docs/decisions/ for observed architectural decisions (framework, database, auth, API format, test framework, background jobs, key libraries). Use templates/adr.md.template. Status: Observed. Do NOT re-scan the codebase." \
        --dangerously-skip-permissions >> "$SESSION_LOG" 2>&1 || true
    else
      log "Step 4/6: Fresh project — skipping ADRs"
    fi
    save_state "bootstrap_adrs" "done"
  fi

  # Sub-step 5: Generate CLAUDE.md + seed memory
  bs_state=$(get_state "bootstrap_config")
  if [ "$bs_state" != "done" ]; then
    log "Step 5/6: Generating CLAUDE.md and seeding memory..."
    claude -p "Run /bootstrap Steps 6-7 ONLY. Generate or update CLAUDE.md from templates/CLAUDE.md.template (append harness section if CLAUDE.md exists — never overwrite). Seed .memory/ from .docs/decisions/ and .pipeline/bootstrap-inventory.md if they exist. Update .memory/index.md." \
      --dangerously-skip-permissions >> "$SESSION_LOG" 2>&1 || true
    save_state "bootstrap_config" "done"
  fi

  # Sub-step 6: Smoke test + MCP setup
  bs_state=$(get_state "bootstrap_verify")
  if [ "$bs_state" != "done" ]; then
    log "Step 6/6: Smoke test and MCP setup..."
    claude -p "Run /bootstrap Steps 9-10 ONLY. Run the smoke test (database connects, tests run, app loads). Report failures. Then configure MCP integration (GitHub if git remote exists, browser automation for full-stack projects). Configure in .claude/settings.json." \
      --dangerously-skip-permissions >> "$SESSION_LOG" 2>&1 || true
    save_state "bootstrap_verify" "done"
  fi

  check_bootstrap && { ok "Bootstrap complete"; save_state "bootstrap" "done"; return 0; }
  fail "Bootstrap incomplete"; save_state "bootstrap" "failed"; return 1
}

run_memory() {
  step_header 2 "memory" "UNDERSTAND"
  log "Memory recall..."
  [ -f "${PROJECT_DIR}/.memory/index.md" ] && ok "Memory index exists" || warn "No prior memory"
  save_state "memory" "done"
}

run_assess() {
  step_header 2.5 "assess" "UNDERSTAND"
  # Skip for new projects (nothing to assess)
  if [ ! -d "${PROJECT_DIR}/app" ] && [ ! -d "${PROJECT_DIR}/src" ] && [ ! -f "${PROJECT_DIR}/main.py" ]; then
    ok "Skipped (new project — nothing to assess)"; save_state "assess" "skipped"; return 0
  fi
  if check_assess; then
    ok "Already complete"; save_state "assess" "done"; return 0
  fi
  log "Running technical assessment (9 specialists + CTO synthesis)..."
  run_claude "Run the /assess skill. Dispatch all 9 specialist agents in 3 batches of 3 (parallel within batch). Each specialist writes to .pipeline/assessment/<name>.md. After all 9 complete, dispatch the CTO orchestrator to synthesize findings into .docs/decisions/technical-assessment-$(date +%Y-%m-%d).md. Present the final report for review."

  if check_assess; then
    ok "Assessment complete"; save_state "assess" "done"
    local verdict
    verdict=$(grep -oP 'Verdict:\s*\K\S+' "${PROJECT_DIR}"/.docs/decisions/technical-assessment-*.md 2>/dev/null | tail -1 || echo "")
    [ -n "$verdict" ] && save_state "assess_verdict" "$verdict"
    return 0
  fi
  fail "No assessment report in .docs/decisions/"; save_state "assess" "failed"; return 1
}

run_brainstorm() {
  step_header 3 "brainstorm" "DECIDE"
  if step_done "brainstorm"; then
    ok "Already complete"; return 0
  fi
  [ -z "${FEATURE_DESC:-}" ] && { fail "No feature description provided"; return 1; }
  log "Design decisions require your input — interactive session..."
  # Brainstorm is ALWAYS interactive. Design decisions have the highest ROI for human input.
  # Wrong design cascades to wrong stories, wrong plan, wrong code.
  run_claude "Run the /brainstorm skill for: ${FEATURE_DESC}

Write a design document to .docs/specs/. Include Problem, Solution, Scope (In/Out), Key Decisions. Perform a scope check — compare the design against the original request and flag if scope expanded. Get user approval before marking as approved." "interactive"
  if check_brainstorm; then
    # Review the design doc — user must approve before proceeding
    local spec_files=()
    while IFS= read -r f; do spec_files+=("$f"); done < <(compgen -G "${PROJECT_DIR}/.docs/specs/*.md" | sort)
    if [ ${#spec_files[@]} -gt 0 ]; then
      if ! review_artifacts "brainstorm" "${spec_files[@]}"; then
        for f in "${spec_files[@]}"; do rm -f "$f"; done
        fail "Design doc rejected — will re-generate"; save_state "brainstorm" "failed"; return 1
      fi
    fi
    ok "Design doc approved"; save_state "brainstorm" "done"
    name_session
    return 0
  fi
  fail "No design doc in .docs/specs/"; save_state "brainstorm" "failed"; return 1
}

run_complexity_assessment() {
  step_header 3.5 "complexity" "DECIDE"
  # Check if already assessed
  if [ -f "$STATE_FILE" ]; then
    local tier
    tier=$(python3 -c "import json; print(json.load(open('$STATE_FILE')).get('complexity_tier',''))" 2>/dev/null || echo "")
    if [ -n "$tier" ]; then
      ok "Complexity tier: ${tier}"; save_state "complexity" "done"; return 0
    fi
  fi
  step_done "brainstorm" || { fail "GATE: Need design doc first"; return 1; }

  # Assess complexity by reading the design doc
  log "Assessing feature complexity from design doc..."
  local tier_output
  tier_output=$(claude -p "Read the design doc in .docs/specs/. Score each signal, then output the tier.

SIGNALS (score each one):
1. Models/tables: 1-3=S, 4-7=M, 8+=L
2. External integrations: 0=S, 1-2=M, 3+=L
3. Auth complexity: None/basic=S, Role-based=M, Multi-tenant/OAuth=L
4. State machines: None=S, 1 simple=M, Complex/multiple=L
5. Estimated stories: 1-5=S, 6-15=M, 16+=L

Output format (exactly):
1. Models: [count] → [S/M/L]
2. Integrations: [count] → [S/M/L]
3. Auth: [description] → [S/M/L]
4. State machines: [count] → [S/M/L]
5. Stories: [count] → [S/M/L]
TIER: [S/M/L]" \
    --dangerously-skip-permissions 2>/dev/null || echo "")

  # Parse tier from last line containing TIER:
  local tier_result
  tier_result=$(echo "$tier_output" | grep -oE 'TIER:\s*[SML]' | tail -1 | grep -oE '[SML]')

  # Fallback: look for any standalone S, M, or L on its own line
  if [ -z "$tier_result" ]; then
    tier_result=$(echo "$tier_output" | grep -xE '\s*[SML]\s*' | tail -1 | tr -d '[:space:]')
  fi

  if [ -z "$tier_result" ]; then
    warn "Could not parse tier from Claude output — defaulting to Medium"
    tier_result="M"
  fi

  # Show reasoning so user can verify
  if [ -n "$tier_output" ]; then
    echo ""
    echo "$tier_output" | tail -8
  fi

  # Show assessment and let user override
  local tier_name
  case "$tier_result" in
    S) tier_name="Small (skips: conflict-check, arch-review, acceptance-specs, pipeline, code-review)" ;;
    M) tier_name="Medium (full flow, lightweight arch-review)" ;;
    L) tier_name="Large (full ceremony)" ;;
  esac
  echo ""
  echo -e "  ${BOLD}Complexity assessment: ${tier_result} — ${tier_name}${NC}"
  echo ""
  # Allow override in interactive modes; skip in auto mode or non-TTY
  if [ "${RUN_MODE}" != "auto" ] && [ -t 0 ]; then
    stop_live_refresh
    read -r -p "  Accept or override [S/M/L/enter=accept]: " override
    case "$override" in
      [Ss]) tier_result="S" ;;
      [Mm]) tier_result="M" ;;
      [Ll]) tier_result="L" ;;
      *)    ;; # accept as-is
    esac
    start_live_refresh 10
  else
    log "Auto mode — accepting complexity tier: ${tier_result}"
  fi

  # Write to state file
  python3 << PYEOF
import json, os
path = "$STATE_FILE"
state = {}
if os.path.exists(path):
    with open(path) as f:
        state = json.load(f)
state["complexity_tier"] = "$tier_result"
with open(path, "w") as f:
    json.dump(state, f, indent=2)
PYEOF

  ok "Complexity tier: ${tier_result}"
  save_state "complexity" "done"
}

# ─── Worktree Management ────────────────────────────────────────────────────

WORKTREE_DIR=""
WORKTREE_BRANCH=""

# Create a worktree for the feature under .worktrees/ (gitignored).
# Handles parallel runs — each feature gets its own worktree.
create_worktree() {
  if ! git rev-parse --is-inside-work-tree &>/dev/null; then
    warn "Not a git repo — skipping worktree"; return 0
  fi
  # Already in a worktree?
  if [ "$(git rev-parse --git-common-dir 2>/dev/null)" != "$(git rev-parse --git-dir 2>/dev/null)" ]; then
    warn "Already in a worktree — skipping"; return 0
  fi

  # Ensure .worktrees/ exists and is gitignored
  mkdir -p "${PROJECT_DIR}/.worktrees"
  if ! grep -qx '.worktrees/' "${PROJECT_DIR}/.gitignore" 2>/dev/null; then
    echo '.worktrees/' >> "${PROJECT_DIR}/.gitignore"
  fi
  if ! grep -qx '.pipeline/' "${PROJECT_DIR}/.gitignore" 2>/dev/null; then
    echo '.pipeline/' >> "${PROJECT_DIR}/.gitignore"
  fi

  # Remove .pipeline/ from git tracking if it was committed before gitignore
  git rm -r --cached .pipeline/ 2>/dev/null || true

  # Commit gitignore updates before creating worktree
  git add .gitignore 2>/dev/null || true
  git diff --cached --quiet 2>/dev/null || \
    git commit -m "Add .worktrees/ and .pipeline/ to gitignore" 2>/dev/null || true

  # Derive branch name from feature description
  local slug
  slug=$(echo "${FEATURE_DESC:-work}" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]/-/g' | sed 's/--*/-/g' | sed 's/^-//;s/-$//' | cut -c1-50)
  WORKTREE_BRANCH="feature/${slug}"

  local wt_path="${PROJECT_DIR}/.worktrees/${slug}"

  # Check if worktree/branch already exists — reuse
  if [ -d "$wt_path" ]; then
    log "Reusing existing worktree: ${wt_path}"
    WORKTREE_DIR="$wt_path"
    ok "Worktree exists: ${WORKTREE_DIR} (branch: ${WORKTREE_BRANCH})"
    return 0
  fi

  # Check if branch exists (from a prior run)
  if git rev-parse --verify "$WORKTREE_BRANCH" &>/dev/null; then
    git worktree add "$wt_path" "$WORKTREE_BRANCH" 2>/dev/null
  else
    git worktree add -b "$WORKTREE_BRANCH" "$wt_path" 2>/dev/null
  fi

  if [ -d "$wt_path" ]; then
    WORKTREE_DIR="$wt_path"
    ok "Worktree created: ${WORKTREE_DIR} (branch: ${WORKTREE_BRANCH})"
  else
    warn "Worktree creation failed — continuing in main directory"
    WORKTREE_DIR=""
    WORKTREE_BRANCH=""
  fi
}

# Switch conduct's working directory to the worktree
enter_worktree() {
  if [ -n "$WORKTREE_DIR" ] && [ -d "$WORKTREE_DIR" ]; then
    PROJECT_DIR="$WORKTREE_DIR"
    PIPELINE_DIR="${PROJECT_DIR}/.pipeline"
    SESSION_LOG="${PIPELINE_DIR}/conduct.log"
    STATE_FILE="${PIPELINE_DIR}/conduct-state.json"
    SESSION_FILE="${PIPELINE_DIR}/conduct-session-id"
    CURRENT_STEP_FILE="${PIPELINE_DIR}/.current-step"
    STEP_START_FILE="${PIPELINE_DIR}/.step-start-time"
    LINES_FILE="${PIPELINE_DIR}/.display-lines"
    REFRESH_STOP_FILE="${PIPELINE_DIR}/.refresh-stop"
    mkdir -p "$PIPELINE_DIR"

    # Remove .pipeline/ from git tracking if it was committed before gitignore
    git rm -r --cached "${PIPELINE_DIR}" 2>/dev/null || true

    # Initialize worktree state only if no state file exists yet.
    # On resume, the state file already has progress — don't overwrite it.
    if [ ! -f "$STATE_FILE" ]; then
      python3 -c "
import json, sys, time
state = {
    'feature_desc': sys.argv[2],
    'worktree': 'done',
    'run_started_at': int(time.time()),
    'last_step': 'worktree'
}
with open(sys.argv[1], 'w') as f:
    json.dump(state, f, indent=2)
" "$STATE_FILE" "${FEATURE_DESC:-}" 2>/dev/null || true
      # Start a fresh Claude session only on first entry (not resume)
      rm -f "$SESSION_FILE" "${PIPELINE_DIR}/session-created"
    fi
    cd "$PROJECT_DIR"
    log "Working in worktree: ${PROJECT_DIR}"
    # Restart live refresh — the background subshell inherited the old
    # PROJECT_DIR/STATE_FILE/etc. and would read from the main repo.
    stop_live_refresh
    start_live_refresh 10
  fi
}

# Dispatch worktree-manager agent to merge and clean up
cleanup_worktree() {
  if [ -z "$WORKTREE_DIR" ] || [ -z "$WORKTREE_BRANCH" ]; then
    return 0
  fi
  log "Dispatching worktree-manager for cleanup..."
  # Cleanup is handled by the finish step's Claude session — it has the
  # merge/PR options and will call the worktree-manager agent internally.
  # Here we just reset state after finish completes.
  WORKTREE_DIR=""
  WORKTREE_BRANCH=""
}

# Save worktree info to state for resume across sessions.
# Only writes to the worktree state file. Resume discovers worktrees
# by scanning .worktrees/ — no writes back to the root repo.
save_worktree_state() {
  if [ -n "$WORKTREE_DIR" ]; then
    python3 -c "
import json, os, sys
path = '$STATE_FILE'
state = {}
if os.path.exists(path):
    with open(path) as f:
        state = json.load(f)
state['worktree_dir'] = sys.argv[1]
state['worktree_branch'] = sys.argv[2]
with open(path, 'w') as f:
    json.dump(state, f, indent=2)
" "$WORKTREE_DIR" "$WORKTREE_BRANCH"
  fi
}

# Restore worktree context on resume.
# Two paths: (1) detect we're already in a worktree (after re-exec) and
# enter it, or (2) scan .worktrees/ for a matching feature and re-exec.
# No reads from root repo state — worktree presence is the source of truth.
restore_worktree_state() {
  # Path 1: already in a git worktree (landed here via re-exec)
  local git_common git_dir
  git_common=$(git rev-parse --git-common-dir 2>/dev/null || echo "")
  git_dir=$(git rev-parse --git-dir 2>/dev/null || echo "")
  if [ -n "$git_common" ] && [ -n "$git_dir" ] && [ "$git_common" != "$git_dir" ]; then
    WORKTREE_DIR="$PROJECT_DIR"
    WORKTREE_BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")
    enter_worktree
    return
  fi

  # Path 2: in main repo — scan .worktrees/ for a matching feature
  if [ -n "$FEATURE_DESC" ] && [ -d "${PROJECT_DIR}/.worktrees" ]; then
    local wt_dir wt_state wt_feat
    for wt_dir in "${PROJECT_DIR}/.worktrees/"*/; do
      [ -d "$wt_dir" ] || continue
      wt_state="${wt_dir}.pipeline/conduct-state.json"
      [ -f "$wt_state" ] || continue
      wt_feat=$(python3 -c "import json; print(json.load(open('$wt_state')).get('feature_desc',''))" 2>/dev/null || echo "")
      if [ "$wt_feat" = "$FEATURE_DESC" ]; then
        WORKTREE_DIR="${wt_dir%/}"
        WORKTREE_BRANCH=$(python3 -c "import json; print(json.load(open('$wt_state')).get('worktree_branch',''))" 2>/dev/null || echo "")
        log "Re-launching from worktree: ${WORKTREE_DIR}"
        cd "$WORKTREE_DIR"
        exec "$0" "${ORIGINAL_ARGS[@]}"
      fi
    done
  fi
}

# Helper: get complexity tier (S/M/L, defaults to M)
get_complexity_tier() {
  if [ -f "$STATE_FILE" ]; then
    python3 -c "import json; print(json.load(open('$STATE_FILE')).get('complexity_tier','M'))" 2>/dev/null || echo "M"
  else
    echo "M"
  fi
}

# Helper: check if a step should be skipped based on complexity tier
should_skip_for_tier() {
  local step=$1
  local tier
  tier=$(get_complexity_tier)
  case "$step" in
    conflict-check)       [ "$tier" = "S" ] && return 0 ;;
    architecture-review)  [ "$tier" = "S" ] && return 0 ;;
    acceptance-specs)     [ "$tier" = "S" ] && return 0 ;;
    code-review)          [ "$tier" = "S" ] && return 0 ;;
  esac
  return 1  # don't skip
}

# ─── Task Extraction from Plan Files ─────────────────────────────────────────

# Find the active plan file.
get_plan_file() {
  # Check for plan-ref first (pipeline sets this)
  if [ -f "${PIPELINE_DIR}/plan-ref.md" ]; then
    local ref
    ref=$(cat "${PIPELINE_DIR}/plan-ref.md" 2>/dev/null | head -1)
    [ -f "$ref" ] && echo "$ref" && return 0
  fi
  # Fallback: most recent plan file
  local latest
  latest=$(ls -t "${PROJECT_DIR}/.docs/plans/"*.md 2>/dev/null | head -1)
  [ -n "$latest" ] && echo "$latest" && return 0
  return 1
}

# Extract task count from a plan file.
get_task_count() {
  local plan_file=$1
  grep -cE '^### Task [0-9]+:' "$plan_file" 2>/dev/null || echo 0
}

# Extract a single task block from the plan file (Task N's full markdown).
# Outputs the text between "### Task N:" and the next "### Task" or "##" header.
extract_task() {
  local plan_file=$1
  local task_num=$2
  python3 -c "
import re, sys

with open(sys.argv[1]) as f:
    content = f.read()

pattern = r'(### Task ' + sys.argv[2] + r':.*?)(?=\n### Task \d+:|\n## [^#]|\Z)'
match = re.search(pattern, content, re.DOTALL)
if match:
    print(match.group(1).strip())
else:
    sys.exit(1)
" "$plan_file" "$task_num"
}

# Extract the "Files likely touched" list from a task block.
extract_task_files() {
  local task_block="$1"
  echo "$task_block" | sed -n '/\*\*Files likely touched:\*\*/,/^\*\*/{ /^\*\*Files/d; /^\*\*/d; p; }' | sed 's/^- //' | sed 's/ — .*//'
}

# Extract the dependency task numbers from a task block.
# Returns "none" or space-separated task numbers like "1 3 5".
extract_task_deps() {
  local task_block="$1"
  local deps_line
  deps_line=$(echo "$task_block" | grep -oP '\*\*Dependencies:\*\*\s*\K.*' || echo "none")
  if echo "$deps_line" | grep -qi "none"; then
    echo "none"
  else
    echo "$deps_line" | grep -oP '\d+' | tr '\n' ' '
  fi
}

# Check if a task is complete in .pipeline/task-status.json.
is_task_complete() {
  local task_num=$1
  [ -f "${PIPELINE_DIR}/task-status.json" ] || return 1
  python3 -c "
import json, sys
with open('${PIPELINE_DIR}/task-status.json') as f:
    state = json.load(f)
task = state.get('task-' + sys.argv[1], state.get('task_' + sys.argv[1], {}))
if isinstance(task, dict) and task.get('status') == 'completed':
    sys.exit(0)
sys.exit(1)
" "$task_num" 2>/dev/null
}

# Mark a task as in_progress or completed in .pipeline/task-status.json.
set_task_status() {
  local task_num=$1
  local status=$2  # in_progress | completed
  python3 -c "
import json, os, sys
path = '${PIPELINE_DIR}/task-status.json'
state = {}
if os.path.exists(path):
    with open(path) as f:
        state = json.load(f)
key = 'task-' + sys.argv[1]
if key not in state:
    state[key] = {}
state[key]['status'] = sys.argv[2]
with open(path, 'w') as f:
    json.dump(state, f, indent=2)
" "$task_num" "$status"
}

run_stories() {
  step_header 4 "stories" "DECIDE"
  if step_done "stories"; then
    ok "Already complete"; return 0
  fi
  step_done "brainstorm" || { fail "GATE: Need design doc in .docs/specs/ first"; return 1; }
  log "Generating stories with mandatory negative paths..."
  run_claude "Run the /stories skill. Read .docs/specs/ and generate stories in .docs/stories/.

REQUIREMENTS:
- Every story: happy path + concrete negative paths (Given/When/Then)
- All 10 negative path categories where applicable
- Stack-specific paths from tech-context if loaded
- NO vague paths like 'handle errors gracefully'"
  if check_stories; then
    # Review each story file before accepting
    local story_files=()
    while IFS= read -r f; do story_files+=("$f"); done < <(compgen -G "${PROJECT_DIR}/.docs/stories/*.md" | sort)
    if [ ${#story_files[@]} -gt 0 ]; then
      if ! review_artifacts "stories" "${story_files[@]}"; then
        # Delete rejected stories so check_stories fails on retry
        for f in "${story_files[@]}"; do rm -f "$f"; done
        fail "Stories rejected — will re-generate"; save_state "stories" "failed"; return 1
      fi
    fi
    ok "Stories created"; save_state "stories" "done"; return 0
  fi
  fail "No accepted stories in .docs/stories/"; save_state "stories" "failed"; return 1
}

run_conflict_check() {
  step_header 5 "conflict-check" "DECIDE"
  if should_skip_for_tier "conflict-check"; then
    ok "Skipped (Small tier)"; save_state "conflict_check" "skipped"; return 0
  fi
  if step_done "conflict_check"; then
    ok "Already complete"; return 0
  fi
  step_done "stories" || { fail "GATE: Need stories in .docs/stories/ first"; return 1; }
  log "Checking for conflicts..."
  run_claude "Run the /conflict-check skill. Check ALL stories against all 5 conflict types. Write report to .docs/conflicts/. If clean, write a clean-check marker. If blocking conflicts found, list them with resolution options but do NOT auto-resolve — the user must choose."

  # Check if blocking conflicts need human resolution
  if check_conflict_check; then
    local has_blocking=false
    # If a clean-check marker exists, there are no blocking conflicts
    if ! compgen -G "${PROJECT_DIR}/.docs/conflicts/*clean-check*" > /dev/null 2>&1; then
      # No clean-check marker — check for blocking conflicts in non-marker files
      has_blocking=true
    fi
    if $has_blocking; then
      warn "Blocking conflicts found — interactive session for resolution..."
      run_claude "There are blocking conflicts in .docs/conflicts/. Present each to the user with resolution options. The user must choose. Update stories after each resolution. Re-run conflict check until clean." "interactive"
      # Verify conflicts were actually resolved
      if ! compgen -G "${PROJECT_DIR}/.docs/conflicts/*clean-check*" > /dev/null 2>&1; then
        fail "Blocking conflicts still unresolved"; save_state "conflict_check" "failed"; return 1
      fi
    fi
    ok "Conflict check complete"; save_state "conflict_check" "done"; return 0
  fi
  fail "No conflict report in .docs/conflicts/"; save_state "conflict_check" "failed"; return 1
}

run_plan() {
  step_header 6 "plan" "DECIDE"
  if step_done "plan"; then
    ok "Already complete"; return 0
  fi
  # Gate: conflict-check must be done or skipped (Small tier skips it)
  local cc_state
  cc_state=$(get_state "conflict_check")
  if [ "$cc_state" != "done" ] && [ "$cc_state" != "skipped" ]; then
    fail "GATE: Need conflict-check first (state: $cc_state)"; return 1
  fi
  log "Generating implementation plan..."
  run_claude "Run the /plan skill. Generate plan in .docs/plans/ with 2-5 min tasks, dependency graph, coverage mapping. Check scope: warn if >20 tasks, hard stop if >40."
  if check_plan; then
    local plan_files=()
    while IFS= read -r f; do plan_files+=("$f"); done < <(compgen -G "${PROJECT_DIR}/.docs/plans/*.md" | sort)
    if [ ${#plan_files[@]} -gt 0 ]; then
      if ! review_artifacts "plan" "${plan_files[@]}"; then
        for f in "${plan_files[@]}"; do rm -f "$f"; done
        fail "Plan rejected — will re-generate"; save_state "plan" "failed"; return 1
      fi
    fi
    ok "Plan created"; save_state "plan" "done"; return 0
  fi
  fail "No plan in .docs/plans/"; save_state "plan" "failed"; return 1
}

run_architecture_review() {
  step_header 7 "architecture-review" "DECIDE"
  if should_skip_for_tier "architecture-review"; then
    ok "Skipped (Small tier)"; save_state "architecture_review" "skipped"; return 0
  fi
  if step_done "architecture_review"; then
    ok "Already complete"; return 0
  fi
  step_done "plan" || { fail "GATE: Need plan in .docs/plans/ first"; return 1; }
  log "Reviewing architecture feasibility and alignment..."
  run_claude "Run the /architecture-review skill. Review all stories and the plan for technical feasibility, architectural alignment, domain integrity, and risks. Write review to .docs/decisions/architecture-review-*.md. Issue APPROVED, APPROVED WITH CONDITIONS, or BLOCKED verdict."

  if check_architecture_review; then
    # Check for BLOCKED verdict — requires human
    if grep -rqiE "verdict.*blocked" "${PROJECT_DIR}"/.docs/decisions/architecture-review-*.md 2>/dev/null; then
      warn "Architecture BLOCKED — interactive session to resolve..."
      run_claude "The architecture review issued a BLOCKED verdict. Present the blocking issues to the user with resolution options. The user must decide. After resolution, update the review and re-issue verdict." "interactive"
    fi
    ok "Architecture review complete"; save_state "architecture_review" "done"; return 0
  fi
  fail "No architecture review in .docs/decisions/"; save_state "architecture_review" "failed"; return 1
}

run_worktree_setup() {
  step_header 0 "worktree" "SETUP"
  # Check if already set up
  if [ -n "$WORKTREE_DIR" ] && [ -d "$WORKTREE_DIR" ]; then
    ok "Already in worktree: ${WORKTREE_DIR}"; save_state "worktree" "done"; return 0
  fi
  local wt_state
  wt_state=$(get_state "worktree")
  if [ "$wt_state" = "done" ] || [ "$wt_state" = "skipped" ]; then
    restore_worktree_state
    ok "Worktree restored"; return 0
  fi

  # Run bootstrap and assess in the MAIN REPO before creating the worktree.
  # These are project-level (run once), their artifacts get committed so
  # worktrees inherit them via git.
  if ! check_bootstrap; then
    log "Running bootstrap in main repo (one-time project setup)..."
    run_bootstrap
  fi
  if ! check_assess; then
    # Only assess existing projects (not empty/new ones)
    if [ -d "${PROJECT_DIR}/app" ] || [ -d "${PROJECT_DIR}/src" ] || [ -f "${PROJECT_DIR}/main.py" ]; then
      log "Running assess in main repo (one-time project assessment)..."
      run_assess
    fi
  fi

  # Commit ONLY project-level artifacts so worktree inherits them.
  # Do NOT commit per-feature artifacts (.docs/specs/, .docs/stories/,
  # .docs/plans/, .docs/conflicts/) — those belong to prior features
  # and would cause the new feature's steps to skip as "Already complete".
  git add .memory/ .gitignore .github/ 2>/dev/null || true
  git add .docs/decisions/ 2>/dev/null || true
  git diff --cached --quiet 2>/dev/null || \
    git commit -m "Project setup: bootstrap + assess artifacts" 2>/dev/null || true

  create_worktree
  if [ -n "$WORKTREE_DIR" ]; then
    enter_worktree
    save_worktree_state
    save_state "worktree" "done"
  else
    save_state "worktree" "skipped"
  fi
}

run_acceptance_specs() {
  step_header 9 "acceptance specs" "BUILD"
  if should_skip_for_tier "acceptance-specs"; then
    ok "Skipped (Small tier — request specs in TDD suffice)"; save_state "acceptance_specs" "skipped"; return 0
  fi
  if step_done "acceptance_specs"; then
    ok "Already complete"; return 0
  fi
  step_done "plan" || { fail "GATE: Need plan in .docs/plans/ first"; return 1; }
  log "Generating failing acceptance specs from stories..."
  run_claude "Run the /writing-system-tests skill. Generate failing acceptance specs from ALL stories.
API projects: tests/integration/ or spec/integration/. Full-stack: tests/e2e/ or spec/system/. Every criterion (happy + negative) becomes a test. Commit the failing specs." "interactive"
  if check_acceptance_specs; then
    ok "Acceptance specs created"; save_state "acceptance_specs" "done"; return 0
  fi
  # Interactive session completed but check can't find specs in known paths.
  # The specs may be in a project-specific location. Trust the session.
  warn "Could not auto-detect acceptance specs location — marking as done (session completed)"
  save_state "acceptance_specs" "done"; return 0
}

run_build() {
  step_header 9 "tdd / pipeline" "BUILD"
  step_done "plan" || { fail "GATE: Need plan first"; return 1; }

  local plan_file
  plan_file=$(get_plan_file) || { fail "No plan file found in .docs/plans/"; return 1; }

  local total_tasks
  total_tasks=$(get_task_count "$plan_file")
  [ "$total_tasks" -eq 0 ] && { fail "No tasks found in plan: $plan_file"; return 1; }

  local tier
  tier=$(get_complexity_tier)

  log "Building from plan: $(basename "$plan_file") (${total_tasks} tasks, tier ${tier})"
  ensure_pipeline_dir

  # Save plan reference for pipeline state
  echo "$plan_file" > "${PIPELINE_DIR}/plan-ref.md"

  # ─── Conductor-driven task loop ──────────────────────────────────────────
  # The conductor owns the loop. Claude orchestrates each task by dispatching
  # subagents. Subagent context is isolated and discarded after completion.
  # The orchestrator's context grows only by summary lines (~2-3 per task).

  local completed=0
  local failed_tasks=""
  local batch_start_task=1
  local batch_size=4  # evaluator runs every N tasks

  for task_num in $(seq 1 "$total_tasks"); do
    # Skip already-completed tasks (resume support)
    if is_task_complete "$task_num"; then
      ok "Task ${task_num}/${total_tasks}: already complete"
      completed=$((completed + 1))
      continue
    fi

    local task_block
    task_block=$(extract_task "$plan_file" "$task_num")
    if [ -z "$task_block" ]; then
      warn "Could not extract task ${task_num} from plan — skipping"
      continue
    fi

    local task_files
    task_files=$(extract_task_files "$task_block")

    log "Task ${task_num}/${total_tasks}: $(echo "$task_block" | head -1 | sed 's/^### //')"
    set_task_status "$task_num" "in_progress"

    # Dispatch task to Claude — it must use subagents for implementation
    run_claude "Implement the following task using the /tdd skill. You MUST dispatch a subagent
via the Agent tool to do the implementation — do NOT implement directly in this session.
The subagent handles the full TDD cycle: RED → DOMAIN → GREEN → DOMAIN → COMMIT.

Provide the subagent with ONLY this task context (do not send the full plan or all stories):

--- TASK ---
${task_block}
--- END TASK ---

After the subagent completes, verify:
1. The test suite passes (run it yourself to confirm)
2. A commit was created for this task
3. Report the result as: PASS or FAIL with reason

Update .pipeline/task-status.json: set task-${task_num} status to 'completed' if PASS."

    # Check if task was completed
    if is_task_complete "$task_num"; then
      ok "Task ${task_num}/${total_tasks}: PASS"
      completed=$((completed + 1))
    else
      fail "Task ${task_num}/${total_tasks}: FAIL"
      failed_tasks="${failed_tasks} ${task_num}"

      # Rework: retry once before moving on
      warn "Retrying task ${task_num}..."
      run_claude "Task ${task_num} failed. Review the test output and error. Dispatch a subagent
to fix the issue and complete the TDD cycle. Update .pipeline/task-status.json on success."

      if is_task_complete "$task_num"; then
        ok "Task ${task_num}/${total_tasks}: PASS (rework)"
        completed=$((completed + 1))
        failed_tasks=$(echo "$failed_tasks" | sed "s/ ${task_num}//")
      else
        fail "Task ${task_num}: failed after rework — continuing to next task"
      fi
    fi

    # Evaluator at batch boundaries (every batch_size tasks)
    if [ $((task_num % batch_size)) -eq 0 ] && [ "$task_num" -lt "$total_tasks" ]; then
      log "Batch boundary (tasks ${batch_start_task}-${task_num}) — dispatching evaluator..."
      run_claude "Dispatch an evaluator subagent via the Agent tool using agents/evaluator.md persona
with model='opus'. Provide it ONLY with:
- The git diff since task ${batch_start_task} started: git diff HEAD~$((task_num - batch_start_task + 1))..HEAD
- The acceptance criteria for tasks ${batch_start_task}-${task_num} from the plan
- Test output summary (run tests, report pass/fail counts)

The evaluator reviews: spec compliance, code quality, domain integrity, security.
Write verdict to .pipeline/audit-trail/batch-${task_num}/review.json.
If BLOCK verdict: stop and report to user. If REQUEST_CHANGES: note for next task."
      batch_start_task=$((task_num + 1))
    fi
  done

  # Final evaluator on the last batch
  if [ "$completed" -gt 0 ] && [ "$batch_start_task" -le "$total_tasks" ]; then
    log "Final batch evaluator (tasks ${batch_start_task}-${total_tasks})..."
    run_claude "Dispatch a final evaluator subagent via the Agent tool using agents/evaluator.md
persona with model='opus'. Review the final batch diff and full branch summary.
Write verdict to .pipeline/audit-trail/final/review.json.
Also write .pipeline/audit-trail/code-review-satisfied.md if APPROVE."
  fi

  # Summary
  log "Build summary: ${completed}/${total_tasks} tasks completed"
  if [ -n "$failed_tasks" ]; then
    warn "Failed tasks:${failed_tasks}"
  fi

  if [ "$completed" -eq "$total_tasks" ]; then
    ok "Build complete — all ${total_tasks} tasks done"
    echo "done" > "${PIPELINE_DIR}/build-complete"
    save_state "build" "done"
    return 0
  else
    fail "Build incomplete — ${completed}/${total_tasks} tasks done"
    save_state "build" "failed"
    return 1
  fi
}

run_finish() {
  step_header 11 "finish" "SHIP"

  log "Fresh verification and completion options..."
  # Always interactive — user must choose merge/PR/keep/discard
  run_claude "Run the /finish skill. Run test suite NOW, check git status, verify ALL story criteria covered. Present all 4 options (merge locally, push & create PR, keep as-is, discard) and wait for the user to choose." "interactive"
  save_state "finish" "done"; ok "Finish complete"
}

run_manual_test() {
  step_header 12 "manual-test" "SHIP"
  if step_done "manual_test"; then
    ok "Already complete — all stories pass manual testing"; return 0
  fi
  log "Running manual tests against stories..."
  # Always interactive — may need user to confirm test results, start servers, etc.
  run_claude "Run the /manual-test skill. Start the application server, then test every story's acceptance criteria using curl (API) or browser (full-stack).

Record results in .docs/manual-test-results.md. For any FAILs, write a failing test (RED), fix it (GREEN), commit, and re-test until all stories pass. Do NOT proceed with bugs remaining." "interactive"

  check_manual_test && { ok "Manual tests all pass"; save_state "manual_test" "done"; return 0; }
  fail "Manual test has FAILs — bugs need fixing"; save_state "manual_test" "failed"; return 1
}

run_retro() {
  step_header 13 "retro" "SHIP"
  if step_done "retro"; then
    ok "Already complete"; return 0
  fi
  log "Running dual retrospective..."
  run_claude "Run the /retro skill. Both parts:
Part A (Harness): correctness, gate quality, autonomy friction
Part B (Application): architecture, code quality, test quality, security, tech debt
Write to .docs/retros/ with file:line references."
  check_retro && { ok "Retro complete"; save_state "retro" "done"; return 0; }
  fail "No retro in .docs/retros/"; save_state "retro" "failed"; return 1
}

# ─── Status Display ───────────────────────────────────────────────────────────

get_phase_detail() {
  local step=$1

  case "$step" in
    brainstorm)
      local count
      count=$(compgen -G "${PROJECT_DIR}/.docs/specs/*.md" 2>/dev/null | wc -l)
      [ "$count" -gt 0 ] && echo "${count} design doc(s)"
      ;;
    complexity)
      local tier
      tier=$(get_complexity_tier 2>/dev/null || echo "")
      if [ -n "$tier" ]; then
        case "$tier" in
          S) echo "Small" ;;
          M) echo "Medium" ;;
          L) echo "Large" ;;
          *) echo "$tier" ;;
        esac
      fi
      ;;
    stories)
      local total=0 draft=0
      total=$(compgen -G "${PROJECT_DIR}/.docs/stories/*.md" 2>/dev/null | wc -l)
      [ "$total" -gt 0 ] && draft=$(grep -rl "Status: DRAFT" "${PROJECT_DIR}/.docs/stories/" 2>/dev/null | wc -l)
      if [ "$total" -gt 0 ]; then
        [ "$draft" -gt 0 ] && echo "${total} stories (${draft} DRAFT)" || echo "${total} stories"
      fi
      ;;
    conflict_check)
      local f="${PROJECT_DIR}/.docs/conflicts/"
      if compgen -G "${f}*.md" > /dev/null 2>&1; then
        if grep -rql "Clean Pass\|clean" "$f" 2>/dev/null; then
          echo "clean"
        else
          local blocking
          blocking=$(grep -rci "blocking" "$f" 2>/dev/null | awk -F: '{s+=$2}END{print s}')
          [ "$blocking" -gt 0 ] && echo "${blocking} blocking" || echo "resolved"
        fi
      fi
      ;;
    plan)
      if compgen -G "${PROJECT_DIR}/.docs/plans/*.md" > /dev/null 2>&1; then
        local tasks
        tasks=$(grep -c "^### Task" "${PROJECT_DIR}"/.docs/plans/*.md 2>/dev/null | awk -F: '{s+=$2}END{print s}')
        [ "$tasks" -gt 0 ] && echo "${tasks} tasks"
      fi
      ;;
    architecture_review)
      if compgen -G "${PROJECT_DIR}/.docs/decisions/architecture-review-*.md" > /dev/null 2>&1; then
        local verdict
        verdict=$(grep -h "Verdict:" "${PROJECT_DIR}"/.docs/decisions/architecture-review-*.md 2>/dev/null | tail -1 | sed 's/.*Verdict:\s*//' | tr -d '*')
        [ -n "$verdict" ] && echo "$verdict"
      fi
      ;;
    acceptance_specs)
      local count=0
      count=$(compgen -G "${PROJECT_DIR}/spec/integration/*_spec.rb" 2>/dev/null | wc -l)
      [ "$count" -eq 0 ] && count=$(compgen -G "${PROJECT_DIR}/spec/system/*_spec.rb" 2>/dev/null | wc -l)
      [ "$count" -gt 0 ] && echo "${count} spec file(s)"
      ;;
    worktree)
      if [ -n "$WORKTREE_DIR" ] && [ -d "$WORKTREE_DIR" ]; then
        echo "${WORKTREE_BRANCH:-$(basename "$WORKTREE_DIR")}"
      fi
      ;;
    build)
      # Show test results — the key visual cue
      local pipeline_detail=""
      if [ -f "${PROJECT_DIR}/.pipeline/task-status.json" ]; then
        pipeline_detail=$(python3 -c "
import json
with open('${PROJECT_DIR}/.pipeline/task-status.json') as f:
    state = json.load(f)
total = len(state)
done = sum(1 for v in state.values() if isinstance(v, dict) and v.get('status') == 'completed')
ip = sum(1 for v in state.values() if isinstance(v, dict) and v.get('status') == 'in_progress')
print(f'{done}/{total} tasks', end='')
if ip > 0:
    print(f' ({ip} active)', end='')
" 2>/dev/null)
      fi

      # Get test counts from log (don't re-run the suite for status display)
      local test_detail=""
      if [ -f "$SESSION_LOG" ]; then
        test_detail=$(grep -oE "[0-9]+ examples?, [0-9]+ failures?" "$SESSION_LOG" 2>/dev/null | tail -1 || true)
      fi
      # Fallback: check for a cached result file
      if [ -z "$test_detail" ] && [ -f "${PIPELINE_DIR}/last-test-result" ]; then
        test_detail=$(cat "${PIPELINE_DIR}/last-test-result" 2>/dev/null || true)
      fi

      local result=""
      [ -n "$pipeline_detail" ] && result="$pipeline_detail"
      if [ -n "$test_detail" ]; then
        # Colorize: green if 0 failures, red otherwise
        if echo "$test_detail" | grep -q "0 failures"; then
          [ -n "$result" ] && result="${result} | "
          result="${result}${GREEN}${test_detail}${NC}"
        else
          [ -n "$result" ] && result="${result} | "
          result="${result}${RED}${test_detail}${NC}"
        fi
      fi
      [ -n "$result" ] && echo "$result"
      ;;
    manual_test)
      local f="${PROJECT_DIR}/.docs/manual-test-results.md"
      if [ -f "$f" ]; then
        local pass fail
        pass=$(grep -ci "| PASS" "$f" 2>/dev/null || echo 0)
        fail=$(grep -ci "| FAIL" "$f" 2>/dev/null || echo 0)
        if [ "$fail" -gt 0 ]; then
          echo "${GREEN}${pass} pass${NC} ${RED}${fail} fail${NC}"
        else
          echo "${GREEN}${pass} pass${NC}"
        fi
      fi
      ;;
    retro)
      if compgen -G "${PROJECT_DIR}/.docs/retros/*.md" > /dev/null 2>&1; then
        echo "complete"
      fi
      ;;
  esac
}

show_status() {
  local session_id="none"
  [ -f "$SESSION_FILE" ] && session_id="$(cat "$SESSION_FILE" | head -c 8)..."

  echo -e "${BOLD}${CYAN}+-------------------------------------------+${NC}"
  echo -e "${BOLD}${CYAN}|      SDLC Conductor - Harness Runner      |${NC}"
  echo -e "${BOLD}${CYAN}+-------------------------------------------+${NC}"
  echo -e "  Project: $(basename "$PROJECT_DIR")"
  [ -n "${FEATURE_DESC:-}" ] && echo -e "  Feature: ${FEATURE_DESC}"
  local location_info="Mode: ${RUN_MODE:-default}"
  [ -n "$WORKTREE_BRANCH" ] && location_info="${location_info}  Branch: ${WORKTREE_BRANCH}"
  echo -e "  ${location_info}"
  echo -e "  ${BOLD}Ctrl+C${NC} pause  ${BOLD}--log${NC} tail output  ${BOLD}--status${NC} check progress"
  echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"

  local steps=("worktree" "memory" "brainstorm" "complexity" "stories" "conflict_check" "plan" "architecture_review" "acceptance_specs" "build" "finish" "manual_test" "retro")
  local labels=("worktree" "memory" "brainstorm" "complexity" "stories" "conflict-check" "plan" "arch review" "acceptance specs" "tdd/pipeline" "finish" "manual-test" "retro")
  local phases=("SETUP" "UNDERSTAND" "DECIDE" "DECIDE" "DECIDE" "DECIDE" "DECIDE" "DECIDE" "BUILD" "BUILD" "SHIP" "SHIP" "SHIP")
  local checks=("" "" check_brainstorm "" check_stories check_conflict_check check_plan check_architecture_review check_acceptance_specs check_build "" check_manual_test check_retro)

  local current_step
  current_step=$(get_current_step)

  for i in "${!steps[@]}"; do
    local state
    state=$(get_state "${steps[$i]}")
    local icon
    local is_active=false

    case "$state" in
      done)     icon="${GREEN}✓${NC}" ;;
      skipped)  icon="${YELLOW}→${NC}" ;;
      failed)   icon="${RED}✗${NC}" ;;
      in_progress)
        icon="${YELLOW}▶${NC}"
        is_active=true
        ;;
      *)
        if [ -n "${checks[$i]}" ] && ${checks[$i]} 2>/dev/null; then
          icon="${GREEN}✓${NC}"
        elif [ "${labels[$i]}" = "$current_step" ]; then
          icon="${YELLOW}▶${NC}"
          is_active=true
        else
          icon="⬚"
        fi
        ;;
    esac

    local detail
    detail=$(get_phase_detail "${steps[$i]}" 2>/dev/null || true)

    if [ -n "$detail" ]; then
      printf "  %b  %-16s  %-10s  %b\n" "$icon" "${labels[$i]}" "${phases[$i]}" "$detail"
    else
      printf "  %b  %-16s  %s\n" "$icon" "${labels[$i]}" "${phases[$i]}"
    fi
  done

  echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"

  # Show activity: elapsed time, log growth, last meaningful line
  local activity_line=""
  if [ -n "$current_step" ]; then
    local elapsed
    elapsed=$(get_step_elapsed)
    local log_size=""
    if [ -f "$SESSION_LOG" ]; then
      local bytes
      bytes=$(stat -c %s "$SESSION_LOG" 2>/dev/null || stat -f %z "$SESSION_LOG" 2>/dev/null || echo 0)
      if [ "$bytes" -gt 1048576 ]; then
        log_size="$(( bytes / 1048576 ))MB"
      elif [ "$bytes" -gt 1024 ]; then
        log_size="$(( bytes / 1024 ))KB"
      elif [ "$bytes" -gt 0 ]; then
        log_size="${bytes}B"
      fi
    fi

    local status_parts="${current_step}"
    [ -n "$elapsed" ] && status_parts="${status_parts} (${elapsed})"
    [ -n "$log_size" ] && status_parts="${status_parts} [log: ${log_size}]"
    activity_line="  ${YELLOW}▶${NC} ${status_parts}"

    # Show last meaningful log line as secondary context
    if [ -f "$SESSION_LOG" ]; then
      local last_line
      last_line=$(grep -v '^$' "$SESSION_LOG" 2>/dev/null | tail -1 | cut -c1-60)
      [ -n "$last_line" ] && activity_line="${activity_line}\n    ${last_line}"
    fi
  fi
  # Clear line then print (handles variable-length content)
  printf "\033[2K%b\n" "$activity_line"
  printf "\033[2K\n"
}

# ─── Live Display ─────────────────────────────────────────────────────────────

# Use a file to share line count between parent and background refresh process
LINES_FILE="${PIPELINE_DIR}/.display-lines"

get_status_lines() {
  cat "$LINES_FILE" 2>/dev/null || echo 0
}

set_status_lines() {
  echo "$1" > "$LINES_FILE" 2>/dev/null
}

reset_display() {
  clear
  set_status_lines 0
  local buffer
  buffer=$(show_status)
  local count
  count=$(echo "$buffer" | wc -l)
  set_status_lines "$count"
  echo "$buffer"
}

refresh_display() {
  [ "${VIEW_MODE}" = "output" ] && return 0

  local prev_lines
  prev_lines=$(get_status_lines)

  # Render new content
  local buffer
  buffer=$(show_status)
  local new_lines
  new_lines=$(echo "$buffer" | wc -l)

  if [ "$prev_lines" -eq 0 ]; then
    clear
    echo "$buffer"
  else
    # Move cursor to top and overwrite
    tput cup 0 0 2>/dev/null || printf "\033[H"
    echo "$buffer"
    # Clear everything below the new content to remove stale lines
    tput ed 2>/dev/null || printf "\033[J"
  fi

  set_status_lines "$new_lines"
}

# Background refresh for long-running steps (build, manual-test)
REFRESH_PID=""

REFRESH_STOP_FILE="${PIPELINE_DIR}/.refresh-stop"

start_live_refresh() {
  # No live refresh in output mode — Claude output owns the terminal
  [ "${VIEW_MODE}" = "output" ] && return 0

  stop_live_refresh  # kill any existing refresh first
  rm -f "$REFRESH_STOP_FILE"

  local interval=${1:-15}
  (
    trap 'exit 0' TERM INT
    while true; do
      # Check stop file every second instead of sleeping the full interval.
      # This makes stop_live_refresh near-instant on WSL2 where signals
      # don't interrupt sleep reliably.
      local waited=0
      while [ "$waited" -lt "$interval" ]; do
        [ -f "$REFRESH_STOP_FILE" ] && exit 0
        sleep 1
        waited=$((waited + 1))
      done
      [ -f "$REFRESH_STOP_FILE" ] && exit 0
      refresh_display 2>/dev/null
    done
  ) &
  REFRESH_PID=$!
}

stop_live_refresh() {
  if [ -n "$REFRESH_PID" ] && kill -0 "$REFRESH_PID" 2>/dev/null; then
    # Signal via file (reliable on WSL2) + kill (belt and suspenders)
    touch "$REFRESH_STOP_FILE" 2>/dev/null
    kill "$REFRESH_PID" 2>/dev/null || true
    # Wait up to 2 seconds, then force kill
    local i=0
    while [ "$i" -lt 20 ] && kill -0 "$REFRESH_PID" 2>/dev/null; do
      sleep 0.1 2>/dev/null || true
      i=$((i + 1))
    done
    kill -9 "$REFRESH_PID" 2>/dev/null || true
    wait "$REFRESH_PID" 2>/dev/null || true
  fi
  REFRESH_PID=""
}

cleanup_and_exit() {
  stop_live_refresh
  echo ""
  log "Paused. State saved."
  show_status
  echo ""
  echo -e "  ${BOLD}Continue options:${NC}"
  echo "    conduct --resume            # pick up where you left off"
  echo "    conduct --from <step>       # restart from a specific step"
  echo "    conduct --status            # check progress without running"
  echo "    conduct --log               # tail the session log"
  echo ""
  exit 130
}

# Clean up on exit, save state on Ctrl+C
trap 'stop_live_refresh' EXIT
trap 'cleanup_and_exit' INT TERM HUP

# ─── Rate Limit ───────────────────────────────────────────────────────────────

handle_rate_limit() {
  local wait_seconds=300  # fallback: 5 minutes
  local marker="${PIPELINE_DIR}/rate-limit-hit"

  # Read actual wait time from marker (line 2) if available
  if [ -f "$marker" ]; then
    local marker_wait
    marker_wait=$(sed -n '2p' "$marker" 2>/dev/null || echo "")
    if [ -n "$marker_wait" ] && [ "$marker_wait" -gt 0 ] 2>/dev/null; then
      wait_seconds="$marker_wait"
    fi
  fi

  local wait_minutes=$(( (wait_seconds + 59) / 60 ))  # round up
  local resume_time
  resume_time=$(date -d "+${wait_seconds} seconds" +%H:%M 2>/dev/null || date -v+${wait_seconds}S +%H:%M 2>/dev/null || echo "~${wait_minutes}m")

  send_notification "Rate limited" "Resuming at ${resume_time} (${wait_minutes}m wait)"
  warn "Rate limit hit. Resuming at ${resume_time} (${wait_seconds}s wait)."

  local end_time=$(($(date +%s) + wait_seconds))
  while [ "$(date +%s)" -lt "$end_time" ]; do
    local remaining=$(( end_time - $(date +%s) ))
    if [ "$remaining" -ge 60 ]; then
      printf "\r  Resuming at %s (~%dm remaining)... " "$resume_time" "$(( (remaining + 59) / 60 ))"
    else
      printf "\r  Resuming in %ds... " "$remaining"
    fi
    sleep 10
  done
  echo ""
  log "Rate limit wait complete. Resuming."
}

# ─── Progress Log ─────────────────────────────────────────────────────────────

PROGRESS_LOG="${PIPELINE_DIR}/progress.log"

append_progress() {
  local prompt_summary=$1
  ensure_pipeline_dir
  local timestamp
  timestamp=$(date "+%Y-%m-%d %H:%M")

  # Extract the step name from the prompt (first few words)
  local step_hint
  step_hint=$(echo "$prompt_summary" | head -1 | cut -c1-80)

  echo "## ${timestamp}" >> "$PROGRESS_LOG"
  echo "- Step: ${step_hint}" >> "$PROGRESS_LOG"

  # Add artifact state
  local done_count=0
  [ -f "$STATE_FILE" ] && done_count=$(python3 -c "
import json
with open('$STATE_FILE') as f:
    s = json.load(f)
print(sum(1 for v in s.values() if v in ('done','skipped')))
" 2>/dev/null || echo 0)
  echo "- Progress: ${done_count}/10 steps" >> "$PROGRESS_LOG"
  echo "" >> "$PROGRESS_LOG"
}

# ─── Notification ─────────────────────────────────────────────────────────────

send_notification() {
  local title=$1
  local message=$2

  # Desktop notification (Linux)
  if command -v notify-send &>/dev/null; then
    notify-send "Conduct: ${title}" "$message" 2>/dev/null || true
  fi

  # macOS notification
  if command -v osascript &>/dev/null; then
    osascript -e "display notification \"${message}\" with title \"Conduct: ${title}\"" 2>/dev/null || true
  fi

  # Terminal bell
  printf '\a'
}

# ─── Recovery ─────────────────────────────────────────────────────────────────

recover() {
  local step_name=$1
  local session_id
  session_id=$(get_session_id)

  # If rate limit was hit, wait for reset instead of dropping to interactive
  # (an interactive session would also be rate-limited, wasting the user's time)
  if [ -f "${PIPELINE_DIR}/rate-limit-hit" ]; then
    rm -f "${PIPELINE_DIR}/rate-limit-hit"
    handle_rate_limit
    log "Rate limit cleared. Retrying step: ${step_name}"
    return 0  # retry the step
  fi

  # Check session log for rate limit indicators (backup detection)
  if [ -f "$SESSION_LOG" ]; then
    local last_lines
    last_lines=$(tail -20 "$SESSION_LOG" 2>/dev/null || true)
    if echo "$last_lines" | grep -qiE "rate.limit|usage.limit|overloaded|429|too.many.requests" 2>/dev/null; then
      warn "Rate/usage limit detected in output. Waiting for reset..."
      handle_rate_limit
      log "Rate limit cleared. Retrying step: ${step_name}"
      return 0  # retry the step
    fi
  fi

  send_notification "Step failed" "${step_name} — needs recovery"

  # Stop refresh BEFORE any output so it can't wipe the recovery menu
  stop_live_refresh
  echo ""
  show_status
  warn "Step failed: ${step_name}."

  # Let the user choose how to recover instead of forcing interactive session
  if [ "${RUN_MODE}" != "auto" ] && [ -t 0 ]; then
    echo ""
    echo -e "  ${BOLD}Recovery options:${NC}"
    echo "    r = retry (re-run the step)"
    echo "    i = interactive Claude session to fix"
    echo "    s = skip this step"
    echo "    q = quit conductor"
    read -r -p "  [r/i/s/q]: " recovery_choice
    case "$recovery_choice" in
      [sS])
        warn "Skipping ${step_name}"
        save_state "$step_name" "skipped"
        start_live_refresh 10
        return 1  # signal caller to advance past this step
        ;;
      [qQ])
        save_state "$step_name" "failed"
        echo -e "Resume later: ${BOLD}conduct --resume${NC}"
        exit 0
        ;;
      [rR])
        log "Retrying ${step_name}..."
        start_live_refresh 10
        return 2  # signal caller to retry without burning retry count
        ;;
      # i or default: fall through to interactive session
    esac
  fi

  sleep 0.2 2>/dev/null || true
  clear
  echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
  echo -e "  ${BOLD}Recovery session${NC} — ${step_name}"
  echo -e "  Type ${BOLD}/quit${NC} when done to return to conductor"
  echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
  echo ""
  STATUS_LINES=0

  local recover_prompt="Run /${step_name}. Complete this step, then stop."
  if [ "$step_name" = "bootstrap" ]; then
    recover_prompt="Run /bootstrap. Detect the project stack, scaffold directories, generate CLAUDE.md. Stop when done."
  elif [ "$step_name" = "brainstorm" ]; then
    recover_prompt="Run /brainstorm for: ${FEATURE_DESC:-this feature}. Write a design doc to .docs/specs/."
  elif [ "$step_name" = "stories" ]; then
    recover_prompt="Run /stories. Read .docs/specs/ and generate stories with negative paths to .docs/stories/."
  elif [ "$step_name" = "build" ]; then
    recover_prompt="Continue the build. Check .pipeline/task-status.json for progress, run /tdd on the next incomplete task."
  fi

  # Fresh session — don't carry context from prior steps
  claude --session-id "$(python3 -c 'import uuid; print(uuid.uuid4())')" \
    --append-system-prompt "Recovery for step: ${step_name}. Complete ONLY this step, then stop and let the user /quit to return to the conductor. Do NOT proceed to subsequent steps." \
    "$recover_prompt" || true
  clear
  reset_display
  start_live_refresh 10
  touch "${PIPELINE_DIR}/session-created"

  log "Back from interactive session. Rechecking..."
  return 0  # always retry the check after interactive fix
}

# ─── Main ─────────────────────────────────────────────────────────────────────

usage() {
  echo "Usage: conduct [options] \"<feature description>\""
  echo ""
  echo "Drives a feature through the full SDLC harness using a persistent Claude session."
  echo ""
  echo "Run modes:"
  echo "  (default)         Dashboard view — status updates in-place, Claude output in log"
  echo "  --auto            Fully hands-off. Dashboard view, Full autonomy pipeline."
  echo "  --interactive     All steps run interactively. You stay in Claude for each step."
  echo "  --output          Output view — show Claude's responses on terminal (no dashboard)"
  echo ""
  echo "Options:"
  echo "  --status          Show current progress (one-shot)"
  echo "  --log             Tail the session log (run in a second terminal)"
  echo "  --resume          Pick up from last completed step"
  echo "  --step <name>     Run a specific step only"
  echo "  --from <name>     Start from a specific step"
  echo "  --reset           Clear session state and start fresh"
  echo "  -h, --help        Show this help"
  echo ""
  echo "Steps: worktree, memory, brainstorm, complexity, stories, conflict-check,"
  echo "       plan, architecture-review, acceptance-specs, build, finish, manual-test, retro"
  echo ""
  echo "Project-level (run once, not per-feature): bootstrap, assess"
  echo ""
  echo "Examples:"
  echo "  conduct --auto \"URL shortener with click tracking\"    # Fully automated"
  echo "  conduct --interactive \"User auth system\"              # Manual oversight"
  echo "  conduct \"Payment processing\"                          # Default: auto with prompts on failure"
}

FEATURE_DESC=""
MODE="full"
RUN_MODE="default"  # default | auto | interactive
VIEW_MODE="dashboard"  # dashboard | output
START_STEP=""
SINGLE_STEP=""
STEP_COOLDOWN=10          # seconds between steps (prevents rate limit bursts)
STEP_COOLDOWN_ORIG=10     # original value for escalation math
CLAUDE_CALL_COUNT=0       # cumulative calls this session

while [[ $# -gt 0 ]]; do
  case $1 in
    --status)       show_status; exit 0 ;;
    --log)          ensure_pipeline_dir; touch "$SESSION_LOG"; exec tail -f "$SESSION_LOG" ;;
    --resume)       MODE="resume" ;;
    --auto)         RUN_MODE="auto" ;;
    --interactive)  RUN_MODE="interactive" ;;
    --output)       VIEW_MODE="output" ;;
    --step)         SINGLE_STEP="$2"; shift ;;
    --from)         START_STEP="$2"; shift ;;
    --cooldown)     STEP_COOLDOWN="$2"; STEP_COOLDOWN_ORIG="$2"; shift ;;
    --reset)        rm -f "$STATE_FILE" "$SESSION_FILE" "${PIPELINE_DIR}/session-created" "${SESSION_LOG}" 2>/dev/null; log "Session reset."; exit 0 ;;
    -h|--help)      usage; exit 0 ;;
    *)              FEATURE_DESC="$1" ;;
  esac
  shift
done

# Resume/from menu: scan .worktrees/ for active features and let user pick.
# Presence of a worktree = work left to do. No root repo state needed.
if ([ "$MODE" = "resume" ] || [ -n "$START_STEP" ]) && [ -z "$FEATURE_DESC" ] && [ -d "${PROJECT_DIR}/.worktrees" ]; then
  resume_options=$(python3 -c "
import json, os, sys

worktrees_dir = os.path.join(sys.argv[1], '.worktrees')
features = []

if os.path.isdir(worktrees_dir):
    for entry in sorted(os.listdir(worktrees_dir)):
        wt_dir = os.path.join(worktrees_dir, entry)
        if not os.path.isdir(wt_dir):
            continue
        state_path = os.path.join(wt_dir, '.pipeline', 'conduct-state.json')
        if not os.path.exists(state_path):
            continue
        try:
            with open(state_path) as f:
                state = json.load(f)
        except (json.JSONDecodeError, IOError):
            continue
        feat = state.get('feature_desc', entry)
        last_step = state.get('last_step', '?')
        status = state.get(last_step, 'pending')
        branch = state.get('worktree_branch', '')
        features.append({
            'desc': feat,
            'step': last_step,
            'status': status,
            'dir': wt_dir,
            'branch': branch
        })

for i, f in enumerate(features):
    print(f\"{i}|{f['desc']}|{f['step']}|{f['status']}|{f['dir']}|{f['branch']}\")
" "$PROJECT_DIR" 2>/dev/null || echo "")

  if [ -z "$resume_options" ]; then
    fail "No active worktrees found. Nothing to resume."
    fail "Start a new feature: conduct \"feature description\""
    exit 1
  fi

  option_count=$(echo "$resume_options" | wc -l)
  selected_wt_dir=""

  if [ "$option_count" -eq 1 ]; then
    # Single feature — auto-select
    FEATURE_DESC=$(echo "$resume_options" | head -1 | cut -d'|' -f2)
    selected_wt_dir=$(echo "$resume_options" | head -1 | cut -d'|' -f5)
    log "Resuming: ${FEATURE_DESC}"
  else
    # Multiple features — show menu
    echo ""
    echo -e "${BOLD}${CYAN}Resume which feature?${NC}"
    echo ""
    while IFS='|' read -r idx desc step status dir branch; do
      local_num=$((idx + 1))
      case "$status" in
        done|skipped) icon="${GREEN}✓${NC}" ;;
        in_progress)  icon="${YELLOW}▶${NC}" ;;
        failed)       icon="${RED}✗${NC}" ;;
        *)            icon="⬚" ;;
      esac
      printf "  %b %d) %-40s  step: %-20s  %s\n" "$icon" "$local_num" "${desc:0:40}" "$step" "$branch"
    done <<< "$resume_options"
    echo ""
    read -r -p "  Select [1-${option_count}]: " pick

    if [[ "$pick" =~ ^[0-9]+$ ]] && [ "$pick" -ge 1 ] && [ "$pick" -le "$option_count" ]; then
      selected_line=$(echo "$resume_options" | sed -n "${pick}p")
      FEATURE_DESC=$(echo "$selected_line" | cut -d'|' -f2)
      selected_wt_dir=$(echo "$selected_line" | cut -d'|' -f5)
    else
      fail "Invalid selection"
      exit 1
    fi
  fi

  # Re-launch from the selected worktree
  if [ -n "$selected_wt_dir" ] && [ -d "$selected_wt_dir" ]; then
    log "Re-launching from worktree: ${selected_wt_dir}"
    cd "$selected_wt_dir"
    exec "$0" "${ORIGINAL_ARGS[@]}" "$FEATURE_DESC"
  fi
fi

# Detect new feature vs resume
if [ -n "$FEATURE_DESC" ] && [ -f "$STATE_FILE" ]; then
  prev_desc=$(python3 -c "import json; print(json.load(open('$STATE_FILE')).get('feature_desc',''))" 2>/dev/null || echo "")
  if [ -n "$prev_desc" ] && [ "$prev_desc" != "$FEATURE_DESC" ]; then
    log "New feature detected — resetting state"
    log "  Previous: ${prev_desc:0:60}"
    log "  New:      ${FEATURE_DESC:0:60}"
    # Reset state but preserve session
    rm -f "$STATE_FILE"
    rm -f "${PIPELINE_DIR}/session-created"
    rm -f "$SESSION_FILE"
    WORKTREE_DIR=""
    WORKTREE_BRANCH=""
  fi
fi

# Save feature description and run start time
if [ -n "$FEATURE_DESC" ]; then
  ensure_pipeline_dir
  python3 -c "
import json, os, sys, time
path = '$STATE_FILE'
state = {}
if os.path.exists(path):
    with open(path) as f:
        state = json.load(f)
state['feature_desc'] = sys.argv[1]
# Record run start time if not already set (new feature or reset)
if 'run_started_at' not in state:
    state['run_started_at'] = int(time.time())
with open(path, 'w') as f:
    json.dump(state, f, indent=2)
" "$FEATURE_DESC"
fi

# Restore feature description from state if resuming without one
if [ -z "$FEATURE_DESC" ] && [ -f "$STATE_FILE" ]; then
  FEATURE_DESC=$(python3 -c "import json; print(json.load(open('$STATE_FILE')).get('feature_desc',''))" 2>/dev/null || echo "")
fi

# Restore worktree state if resuming
restore_worktree_state

ensure_pipeline_dir

# Single step mode
if [ -n "$SINGLE_STEP" ]; then
  case "$SINGLE_STEP" in
    bootstrap)                              run_bootstrap ;;
    memory)                                 run_memory ;;
    assess)                                 run_assess ;;
    brainstorm)                             run_brainstorm ;;
    complexity)                             run_complexity_assessment ;;
    worktree)                               run_worktree_setup ;;
    stories)                                run_stories ;;
    conflict-check|conflict_check)          run_conflict_check ;;
    plan)                                   run_plan ;;
    architecture-review|architecture_review) run_architecture_review ;;
    acceptance-specs|acceptance_specs|writing-system-tests) run_acceptance_specs ;;
    build)                                  run_build ;;
    finish)                                 run_finish ;;
    manual-test|manual_test)                run_manual_test ;;
    retro)                                  run_retro ;;
    *) fail "Unknown step: $SINGLE_STEP"; usage; exit 1 ;;
  esac
  show_status
  exit 0
fi

# Step registry — use underscores to match save_state() keys in conduct-state.json
# Worktree is created right after complexity assessment so all subsequent commits
# (stories, plan, build, etc.) are isolated on the feature branch.
ALL_STEPS=(worktree memory brainstorm complexity stories conflict_check plan architecture_review acceptance_specs build finish manual_test retro)
STEP_FUNCS=(run_worktree_setup run_memory run_brainstorm run_complexity_assessment run_stories run_conflict_check run_plan run_architecture_review run_acceptance_specs run_build run_finish run_manual_test run_retro)

# Determine starting point
start_index=0

if [ "$MODE" = "resume" ] || [ -n "$START_STEP" ]; then
  if [ "$MODE" = "resume" ] && [ -f "$STATE_FILE" ]; then
    last=$(python3 -c "import json; print(json.load(open('$STATE_FILE')).get('last_step','bootstrap'))")
    last_status=$(python3 -c "import json; s=json.load(open('$STATE_FILE')); print(s.get('$last','pending'))" 2>/dev/null || echo "pending")

    for i in "${!ALL_STEPS[@]}"; do
      if [ "${ALL_STEPS[$i]}" = "$last" ]; then
        if [ "$last_status" = "done" ] || [ "$last_status" = "skipped" ]; then
          start_index=$((i + 1))  # Step succeeded — start from next
        else
          start_index=$i  # Step failed — retry it
        fi
        break
      fi
    done
    log "Resuming at: ${ALL_STEPS[$start_index]:-done} (last: $last = $last_status)"
  elif [ -n "$START_STEP" ]; then
    # Normalize dashes to underscores for matching
    normalized_start="${START_STEP//-/_}"
    for i in "${!ALL_STEPS[@]}"; do
      if [ "${ALL_STEPS[$i]}" = "$normalized_start" ]; then
        start_index=$i
        break
      fi
    done
    log "Starting from: $START_STEP"
    # Mark all prior steps as done — they're assumed complete when using --from
    for j in "${!ALL_STEPS[@]}"; do
      [ "$j" -ge "$start_index" ] && break
      prev_state=$(get_state "${ALL_STEPS[$j]}")
      if [ "$prev_state" != "done" ] && [ "$prev_state" != "skipped" ]; then
        save_state "${ALL_STEPS[$j]}" "done"
      fi
    done
  fi
fi

# Check feature description needed
if [ -z "$FEATURE_DESC" ] && [ "$start_index" -le 2 ]; then
  if ! check_brainstorm; then
    fail "Feature description required. Usage: conduct \"description\""
    exit 1
  fi
fi


# ─── Main Loop ────────────────────────────────────────────────────────────────

# Initial display + start live refresh for the entire run
reset_display
start_live_refresh 10

i=$start_index
max_retries=3
retry_count=0

while [ "$i" -lt "${#STEP_FUNCS[@]}" ]; do
  # Record which step we're attempting so --resume lands here if we crash
  save_state "${ALL_STEPS[$i]}" "in_progress"

  if ${STEP_FUNCS[$i]}; then
    refresh_display
    retry_count=0
    i=$((i + 1))
    continue
  fi

  # Step failed — try interactive recovery (up to max_retries)
  retry_count=$((retry_count + 1))
  if [ "$retry_count" -ge "$max_retries" ]; then
    stop_live_refresh
    fail "Step ${ALL_STEPS[$i]} failed after $max_retries attempts."
    save_state "${ALL_STEPS[$i]}" "failed"
    # Offer skip for non-gating steps instead of hard stop
    if [ "${RUN_MODE}" != "auto" ] && [ -t 0 ]; then
      read -r -p "  [s=skip this step / q=quit]: " choice
      start_live_refresh 10
      if [ "$choice" = "s" ] || [ "$choice" = "S" ]; then
        warn "Skipping ${ALL_STEPS[$i]}"
        save_state "${ALL_STEPS[$i]}" "skipped"
        retry_count=0
        i=$((i + 1))
        continue
      fi
    fi
    break
  fi

  recover "${ALL_STEPS[$i]}" && recover_rc=0 || recover_rc=$?
  if [ "$recover_rc" -eq 0 ]; then
    # Interactive fix session completed — retry the step
    refresh_display
    continue
  elif [ "$recover_rc" -eq 1 ]; then
    # User chose skip
    refresh_display
    retry_count=0
    i=$((i + 1))
    continue
  elif [ "$recover_rc" -eq 2 ]; then
    # User chose retry — don't burn retry count
    retry_count=$((retry_count - 1))
    refresh_display
    continue
  else
    fail "Step ${ALL_STEPS[$i]} could not be recovered. Stopping."
    save_state "${ALL_STEPS[$i]}" "failed"
    break
  fi
done

# Done — show final status
stop_live_refresh
refresh_display

# Only declare complete if we actually finished all steps
if [ "$i" -ge "${#STEP_FUNCS[@]}" ]; then
  send_notification "SDLC complete" "All steps finished."

  # Commit any uncommitted artifacts (retro, manual-test results, etc.)
  log "Committing final artifacts..."
  git add .docs/ .pipeline/ .memory/ 2>/dev/null || true
  if ! git diff --cached --quiet 2>/dev/null; then
    git commit -m "Add SHIP phase artifacts: retro, manual-test results

Co-Authored-By: conduct" 2>/dev/null || true
  fi

  # Delegate push + PR creation to Claude via the /pr skill.
  # The PR skill handles verification, push, and PR creation.
  # Conduct does NOT push directly — only Claude does, after confirming all checks pass.
  log "Creating PR via /pr skill..."
  run_claude "Run the /pr skill. Verify all checks pass locally (tests, lint, type-check — whatever this project uses) BEFORE pushing. Only push and create the PR after all checks pass. If any check fails, fix the issue first." "interactive"

  pr_url=$(gh pr view --json url -q '.url' 2>/dev/null || echo "")
  [ -n "$pr_url" ] && ok "PR: ${pr_url}"

  echo ""
  echo -e "${GREEN}${BOLD}SDLC complete.${NC}"
  [ -n "$pr_url" ] && echo -e "  PR: ${pr_url}"
  echo "  Retro: $(ls .docs/retros/*.md 2>/dev/null | head -1 || echo '.docs/retros/')"
  echo "  Cleanup: conduct --reset"
  echo ""
else
  send_notification "SDLC stopped" "Failed at step: ${ALL_STEPS[$i]}"
  if [ -n "$WORKTREE_DIR" ] && [ "$WORKTREE_DIR" != "$ORIGINAL_CWD" ]; then
    echo -e "${RED}${BOLD}SDLC stopped${NC} at step: ${ALL_STEPS[$i]}"
    echo -e "  Worktree: ${WORKTREE_DIR}"
    echo -e "  Resume:   cd ${WORKTREE_DIR} && conduct --resume"
  else
    echo -e "${RED}${BOLD}SDLC stopped${NC} at step: ${ALL_STEPS[$i]}. Resume with: ${BOLD}conduct --resume${NC}"
  fi
fi

exit 0
