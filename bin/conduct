#!/usr/bin/env bash
set -euo pipefail

# conduct — Drives a feature through the full SDLC harness.
#
# Uses a persistent Claude session (Ralph-style loop):
#   - Single session ID maintained across all steps
#   - --resume to continue context between invocations
#   - --output-format stream-json for real-time output parsing
#   - Interactive recovery on failure (retry, skip, manual fix, quit)
#
# Usage:
#   conduct "Build a URL shortener API"
#   conduct --resume
#   conduct --status
#   conduct --step bootstrap
#   conduct --from plan

HARNESS_DIR="$(cd "$(dirname "$0")/.." && pwd)"
PROJECT_DIR="$(pwd)"
PIPELINE_DIR="${PROJECT_DIR}/.pipeline"
SESSION_LOG="${PIPELINE_DIR}/conduct.log"
STATE_FILE="${PIPELINE_DIR}/conduct-state.json"
SESSION_FILE="${PIPELINE_DIR}/conduct-session-id"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'
BOLD='\033[1m'

# ─── Helpers ──────────────────────────────────────────────────────────────────

log()  { echo -e "${BLUE}[conduct]${NC} $*"; }
ok()   { echo -e "${GREEN}  ✓${NC} $*"; }
fail() { echo -e "${RED}  ✗${NC} $*"; }
warn() { echo -e "${YELLOW}  ⚠${NC} $*"; }

step_header() {
  local num=$1 name=$2 phase=$3
  echo ""
  echo -e "${BOLD}${CYAN}━━━ Step ${num}: ${name} (${phase}) ━━━${NC}"
}

ensure_pipeline_dir() {
  mkdir -p "${PIPELINE_DIR}"
}

# ─── Session Management ──────────────────────────────────────────────────────

get_session_id() {
  if [ -f "$SESSION_FILE" ]; then
    cat "$SESSION_FILE"
  else
    local sid
    sid=$(python3 -c "import uuid; print(uuid.uuid4())")
    echo "$sid" > "$SESSION_FILE"
    echo "$sid"
  fi
}

# ─── State Management ────────────────────────────────────────────────────────

save_state() {
  local step=$1 status=$2
  ensure_pipeline_dir
  python3 << PYEOF
import json, os
path = "$STATE_FILE"
state = {}
if os.path.exists(path):
    with open(path) as f:
        state = json.load(f)
state["$step"] = "$status"
state["last_step"] = "$step"
with open(path, "w") as f:
    json.dump(state, f, indent=2)
PYEOF
}

get_state() {
  local step=$1
  if [ -f "$STATE_FILE" ]; then
    python3 -c "
import json
with open('$STATE_FILE') as f:
    state = json.load(f)
print(state.get('$step', 'pending'))
"
  else
    echo "pending"
  fi
}

# ─── Claude Invocation ────────────────────────────────────────────────────────

run_claude() {
  local prompt=$1
  local mode=${2:-print}  # "print" or "interactive"
  local session_id
  session_id=$(get_session_id)

  ensure_pipeline_dir

  # First successful call uses --session-id (creates session).
  # Subsequent calls use --resume (continues session).
  # The marker file is only created AFTER a successful call.
  local session_flag
  if [ -f "${PIPELINE_DIR}/session-created" ]; then
    session_flag="--resume ${session_id}"
  else
    session_flag="--session-id ${session_id}"
  fi

  # Build loop context
  local iteration
  iteration=$(python3 -c "
import json, os
path = '$STATE_FILE'
if os.path.exists(path):
    with open(path) as f:
        state = json.load(f)
    done = sum(1 for v in state.values() if v in ('done', 'skipped') and not v == state.get('last_step'))
    print(done)
else:
    print(0)
")
  local context="[Conduct step ${iteration}/10] Feature: ${FEATURE_DESC:-unknown}"

  if [ "$mode" = "print" ]; then
    log "Sending to Claude (session: ${session_id:0:8}...)..."

    claude -p "$prompt" \
      $session_flag \
      --append-system-prompt "$context" \
      --dangerously-skip-permissions \
      2>&1 | tee -a "$SESSION_LOG"

    local exit_code=${PIPESTATUS[0]}
    if [ "$exit_code" -eq 0 ]; then
      touch "${PIPELINE_DIR}/session-created"
    fi
  else
    log "Interactive session (session: ${session_id:0:8}...). Type /quit when done."
    claude $session_flag --append-system-prompt "$context. $prompt"
    touch "${PIPELINE_DIR}/session-created"
  fi
}

# ─── Artifact Checks ─────────────────────────────────────────────────────────

check_bootstrap() {
  [ -d "${PROJECT_DIR}/.memory" ] && \
  [ -d "${PROJECT_DIR}/docs/specs" ] && \
  [ -d "${PROJECT_DIR}/docs/stories" ] && \
  [ -d "${PROJECT_DIR}/docs/plans" ]
}

check_brainstorm() {
  compgen -G "${PROJECT_DIR}/docs/specs/*.md" > /dev/null 2>&1
}

check_stories() {
  compgen -G "${PROJECT_DIR}/docs/stories/*.md" > /dev/null 2>&1 || return 1
  # DRAFT stories don't count as complete
  if grep -rl "Status: DRAFT" "${PROJECT_DIR}/docs/stories/" > /dev/null 2>&1; then
    return 1
  fi
  return 0
}

check_conflict_check() {
  compgen -G "${PROJECT_DIR}/docs/conflicts/*.md" > /dev/null 2>&1
}

check_plan() {
  compgen -G "${PROJECT_DIR}/docs/plans/*.md" > /dev/null 2>&1
}

check_acceptance_specs() {
  compgen -G "${PROJECT_DIR}/spec/integration/*_spec.rb" > /dev/null 2>&1 || \
  compgen -G "${PROJECT_DIR}/spec/system/*_spec.rb" > /dev/null 2>&1
}

check_build() {
  if [ -f "${PROJECT_DIR}/.rspec" ] || [ -d "${PROJECT_DIR}/spec" ]; then
    cd "$PROJECT_DIR" && bundle exec rspec --no-color 2>&1 | tail -1 | grep -q "0 failures" 2>/dev/null
  elif [ -f "${PROJECT_DIR}/package.json" ]; then
    cd "$PROJECT_DIR" && npm test 2>&1 | tail -1 | grep -qiE "passed|success" 2>/dev/null
  else
    return 1
  fi
}

check_retro() {
  compgen -G "${PROJECT_DIR}/docs/retros/*.md" > /dev/null 2>&1
}

# ─── Step Definitions ─────────────────────────────────────────────────────────

run_bootstrap() {
  step_header 1 "bootstrap" "UNDERSTAND"
  if check_bootstrap; then
    ok "Already complete"; save_state "bootstrap" "done"; return 0
  fi
  log "Detecting project stack and scaffolding..."
  run_claude "Run the /bootstrap skill. Detect project type, tech stack, scaffold directories (.memory/, docs/, .pipeline/), generate CLAUDE.md, run smoke test. If this is an empty directory, scaffold the project first (Rails API + PostgreSQL with Docker for this project)."
  check_bootstrap && { ok "Bootstrap complete"; save_state "bootstrap" "done"; return 0; }
  fail "Bootstrap incomplete"; save_state "bootstrap" "failed"; return 1
}

run_memory() {
  step_header 2 "memory" "UNDERSTAND"
  log "Memory recall..."
  [ -f "${PROJECT_DIR}/.memory/index.md" ] && ok "Memory index exists" || warn "No prior memory"
  save_state "memory" "done"
}

run_brainstorm() {
  step_header 3 "brainstorm" "DECIDE"
  if check_brainstorm; then
    ok "Already complete"; save_state "brainstorm" "done"; return 0
  fi
  [ -z "${FEATURE_DESC:-}" ] && { fail "No feature description provided"; return 1; }
  log "Generating design doc..."
  run_claude "Run the /brainstorm skill for: ${FEATURE_DESC}

Write a design document to docs/specs/. Include Problem, Solution, Scope (In/Out), Key Decisions. Perform a scope check — compare the design against the original request and flag if scope expanded. Mark as approved."
  check_brainstorm && { ok "Design doc created"; save_state "brainstorm" "done"; return 0; }
  fail "No design doc in docs/specs/"; save_state "brainstorm" "failed"; return 1
}

run_stories() {
  step_header 4 "stories" "DECIDE"
  if check_stories; then
    ok "Already complete"; save_state "stories" "done"; return 0
  fi
  check_brainstorm || { fail "GATE: Need design doc in docs/specs/ first"; return 1; }
  log "Generating stories with mandatory negative paths..."
  run_claude "Run the /stories skill. Read docs/specs/ and generate stories in docs/stories/.

REQUIREMENTS:
- Every story: happy path + concrete negative paths (Given/When/Then)
- All 10 negative path categories where applicable
- Stack-specific paths from tech-context if loaded
- NO vague paths like 'handle errors gracefully'"
  check_stories && { ok "Stories created"; save_state "stories" "done"; return 0; }
  fail "No accepted stories in docs/stories/"; save_state "stories" "failed"; return 1
}

run_conflict_check() {
  step_header 5 "conflict-check" "DECIDE"
  if check_conflict_check; then
    ok "Already complete"; save_state "conflict_check" "done"; return 0
  fi
  check_stories || { fail "GATE: Need stories in docs/stories/ first"; return 1; }
  log "Checking for conflicts..."
  run_claude "Run the /conflict-check skill. Check ALL stories against all 5 conflict types. Write report to docs/conflicts/. If clean, write a clean-check marker. Resolve any blocking conflicts and re-check."
  check_conflict_check && { ok "Conflict check complete"; save_state "conflict_check" "done"; return 0; }
  fail "No conflict report in docs/conflicts/"; save_state "conflict_check" "failed"; return 1
}

run_plan() {
  step_header 6 "plan" "DECIDE"
  if check_plan; then
    ok "Already complete"; save_state "plan" "done"; return 0
  fi
  check_conflict_check || { fail "GATE: Need clean conflict-check first"; return 1; }
  log "Generating implementation plan..."
  run_claude "Run the /plan skill. Generate plan in docs/plans/ with 2-5 min tasks, dependency graph, coverage mapping. Check scope: warn if >20 tasks, hard stop if >40."
  check_plan && { ok "Plan created"; save_state "plan" "done"; return 0; }
  fail "No plan in docs/plans/"; save_state "plan" "failed"; return 1
}

run_acceptance_specs() {
  step_header 7 "acceptance specs" "BUILD"
  if check_acceptance_specs; then
    ok "Already complete"; save_state "acceptance_specs" "done"; return 0
  fi
  check_plan || { fail "GATE: Need plan in docs/plans/ first"; return 1; }
  log "Generating failing acceptance specs from stories..."
  run_claude "Run the /writing-system-tests skill. Generate failing acceptance specs from ALL stories.
API projects: spec/integration/. Full-stack: spec/system/. Every criterion (happy + negative) becomes a test. Commit the failing specs."
  check_acceptance_specs && { ok "Acceptance specs created"; save_state "acceptance_specs" "done"; return 0; }
  fail "No acceptance specs found"; save_state "acceptance_specs" "failed"; return 1
}

run_build() {
  step_header 8 "tdd / pipeline" "BUILD"
  check_plan || { fail "GATE: Need plan first"; return 1; }

  local autonomy="Standard"
  local mode="print"
  if [ "${RUN_MODE}" = "interactive" ]; then
    mode="interactive"
  elif [ "${RUN_MODE}" = "auto" ]; then
    autonomy="Full"
  fi

  log "Starting TDD pipeline (${autonomy} autonomy, ${mode} mode)..."
  run_claude "Run the /pipeline skill at ${autonomy} autonomy. Execute each task via TDD (RED→DOMAIN→GREEN→DOMAIN→COMMIT).

MANDATORY at batch boundaries:
- Dispatch evaluator with fresh context (hard gate)
- Run linter (standardrb)
- Run /simplify for duplication
- Persist at least one .memory/ entry per batch
- Run micro-retro

Track state in .pipeline/. Follow rework budget (3 cycles, then escalate).
Do NOT stop to ask for approval — execute all tasks to completion." "$mode"

  check_build && { ok "Build complete — tests passing"; save_state "build" "done"; return 0; }
  warn "Build may be incomplete — checking tests"; save_state "build" "needs_verification"; return 0
}

run_finish() {
  step_header 9 "finish" "SHIP"
  local mode="print"
  [ "${RUN_MODE}" = "interactive" ] && mode="interactive"

  log "Fresh verification..."
  run_claude "Run the /finish skill. Run test suite NOW, check git status, verify ALL story criteria covered. Choose 'keep as-is' for completion." "$mode"
  save_state "finish" "done"; ok "Finish complete"
}

run_retro() {
  step_header 10 "retro" "SHIP"
  if check_retro; then
    ok "Already complete"; save_state "retro" "done"; return 0
  fi
  log "Running dual retrospective..."
  run_claude "Run the /retro skill. Both parts:
Part A (Harness): correctness, gate quality, autonomy friction
Part B (Application): architecture, code quality, test quality, security, tech debt
Write to docs/retros/ with file:line references."
  check_retro && { ok "Retro complete"; save_state "retro" "done"; return 0; }
  fail "No retro in docs/retros/"; save_state "retro" "failed"; return 1
}

# ─── Status Display ───────────────────────────────────────────────────────────

show_status() {
  echo ""
  echo -e "${BOLD}SDLC Progress${NC}"

  local session_id="none"
  [ -f "$SESSION_FILE" ] && session_id="$(cat "$SESSION_FILE" | head -c 8)..."

  echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
  echo -e "  Session: ${session_id}"
  echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"

  local steps=("bootstrap" "memory" "brainstorm" "stories" "conflict_check" "plan" "acceptance_specs" "build" "finish" "retro")
  local labels=("bootstrap" "memory" "brainstorm" "stories" "conflict-check" "plan" "acceptance specs" "tdd/pipeline" "finish" "retro")
  local phases=("UNDERSTAND" "UNDERSTAND" "DECIDE" "DECIDE" "DECIDE" "DECIDE" "BUILD" "BUILD" "SHIP" "SHIP")
  local checks=(check_bootstrap "" check_brainstorm check_stories check_conflict_check check_plan check_acceptance_specs check_build "" check_retro)

  for i in "${!steps[@]}"; do
    local state
    state=$(get_state "${steps[$i]}")
    local icon
    case "$state" in
      done)     icon="${GREEN}✓${NC}" ;;
      skipped)  icon="${YELLOW}→${NC}" ;;
      failed)   icon="${RED}✗${NC}" ;;
      *)
        if [ -n "${checks[$i]}" ] && ${checks[$i]} 2>/dev/null; then
          icon="${GREEN}✓${NC}"
        else
          icon="⬚"
        fi
        ;;
    esac
    printf "  %b  %-16s  %s\n" "$icon" "${labels[$i]}" "${phases[$i]}"
  done

  echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
  echo ""
}

# ─── Notification ─────────────────────────────────────────────────────────────

send_notification() {
  local title=$1
  local message=$2

  # Desktop notification (Linux)
  if command -v notify-send &>/dev/null; then
    notify-send "Conduct: ${title}" "$message" 2>/dev/null || true
  fi

  # macOS notification
  if command -v osascript &>/dev/null; then
    osascript -e "display notification \"${message}\" with title \"Conduct: ${title}\"" 2>/dev/null || true
  fi

  # Terminal bell
  printf '\a'
}

# ─── Recovery ─────────────────────────────────────────────────────────────────

recover() {
  local step_name=$1
  local session_id
  session_id=$(get_session_id)

  send_notification "Step failed" "${step_name} — dropping to interactive session"

  echo ""
  show_status
  warn "Step failed: ${step_name}. Dropping into interactive session to resolve."
  log "Fix the issue, then /quit to return to the conductor."
  echo ""

  local recover_flag="--session-id ${session_id}"
  [ -f "${PIPELINE_DIR}/session-created" ] && recover_flag="--resume ${session_id}"
  claude $recover_flag --append-system-prompt "The conduct script hit a failure at step: ${step_name}. Complete this step, then /quit to return to the conductor."
  touch "${PIPELINE_DIR}/session-created"

  log "Back from interactive session. Rechecking..."
  return 0  # always retry the check after interactive fix
}

# ─── Main ─────────────────────────────────────────────────────────────────────

usage() {
  echo "Usage: conduct [options] \"<feature description>\""
  echo ""
  echo "Drives a feature through the full SDLC harness using a persistent Claude session."
  echo ""
  echo "Run modes:"
  echo "  (default)         Each step runs non-interactively; prompts on failure"
  echo "  --auto            Fully hands-off. All steps non-interactive, auto-retry on failure,"
  echo "                    pipeline at Full autonomy. Only stops after 3 retries exhausted."
  echo "  --interactive     All steps run interactively. You stay in Claude for each step."
  echo ""
  echo "Options:"
  echo "  --status          Show current progress"
  echo "  --resume          Pick up from last completed step"
  echo "  --step <name>     Run a specific step only"
  echo "  --from <name>     Start from a specific step"
  echo "  --reset           Clear session state and start fresh"
  echo "  -h, --help        Show this help"
  echo ""
  echo "Steps: bootstrap, memory, brainstorm, stories, conflict-check, plan,"
  echo "       acceptance-specs, build, finish, retro"
  echo ""
  echo "Examples:"
  echo "  conduct --auto \"URL shortener with click tracking\"    # Fully automated"
  echo "  conduct --interactive \"User auth system\"              # Manual oversight"
  echo "  conduct \"Payment processing\"                          # Default: auto with prompts on failure"
}

FEATURE_DESC=""
MODE="full"
RUN_MODE="default"  # default | auto | interactive
START_STEP=""
SINGLE_STEP=""

while [[ $# -gt 0 ]]; do
  case $1 in
    --status)       show_status; exit 0 ;;
    --resume)       MODE="resume" ;;
    --auto)         RUN_MODE="auto" ;;
    --interactive)  RUN_MODE="interactive" ;;
    --step)         SINGLE_STEP="$2"; shift ;;
    --from)         START_STEP="$2"; shift ;;
    --reset)        rm -f "$STATE_FILE" "$SESSION_FILE" "${PIPELINE_DIR}/session-created" "${SESSION_LOG}" 2>/dev/null; log "Session reset."; exit 0 ;;
    -h|--help)      usage; exit 0 ;;
    *)              FEATURE_DESC="$1" ;;
  esac
  shift
done

# Header
echo ""
echo -e "${BOLD}${CYAN}╔══════════════════════════════════════════╗${NC}"
echo -e "${BOLD}${CYAN}║     SDLC Conductor — Harness Runner     ║${NC}"
echo -e "${BOLD}${CYAN}╚══════════════════════════════════════════╝${NC}"
echo -e "  Project: ${PROJECT_DIR}"
[ -n "$FEATURE_DESC" ] && echo -e "  Feature: ${FEATURE_DESC}"
echo -e "  Mode:    ${RUN_MODE}"
echo ""

ensure_pipeline_dir

# Single step mode
if [ -n "$SINGLE_STEP" ]; then
  case "$SINGLE_STEP" in
    bootstrap)            run_bootstrap ;;
    memory)               run_memory ;;
    brainstorm)           run_brainstorm ;;
    stories)              run_stories ;;
    conflict-check)       run_conflict_check ;;
    plan)                 run_plan ;;
    acceptance-specs|writing-system-tests) run_acceptance_specs ;;
    build)                run_build ;;
    finish)               run_finish ;;
    retro)                run_retro ;;
    *) fail "Unknown step: $SINGLE_STEP"; usage; exit 1 ;;
  esac
  show_status
  exit 0
fi

# Step registry
ALL_STEPS=(bootstrap memory brainstorm stories conflict-check plan acceptance-specs build finish retro)
STEP_FUNCS=(run_bootstrap run_memory run_brainstorm run_stories run_conflict_check run_plan run_acceptance_specs run_build run_finish run_retro)

# Determine starting point
start_index=0

if [ "$MODE" = "resume" ] || [ -n "$START_STEP" ]; then
  if [ "$MODE" = "resume" ] && [ -f "$STATE_FILE" ]; then
    last=$(python3 -c "import json; print(json.load(open('$STATE_FILE')).get('last_step','bootstrap'))")
    for i in "${!ALL_STEPS[@]}"; do
      if [ "${ALL_STEPS[$i]}" = "$last" ]; then
        start_index=$((i + 1))
        break
      fi
    done
    log "Resuming after: $last"
  elif [ -n "$START_STEP" ]; then
    for i in "${!ALL_STEPS[@]}"; do
      if [ "${ALL_STEPS[$i]}" = "$START_STEP" ]; then
        start_index=$i
        break
      fi
    done
    log "Starting from: $START_STEP"
  fi
fi

# Check feature description needed
if [ -z "$FEATURE_DESC" ] && [ "$start_index" -le 2 ]; then
  if ! check_brainstorm; then
    fail "Feature description required. Usage: conduct \"description\""
    exit 1
  fi
fi

# ─── Main Loop ────────────────────────────────────────────────────────────────

i=$start_index
while [ "$i" -lt "${#STEP_FUNCS[@]}" ]; do
  if ${STEP_FUNCS[$i]}; then
    i=$((i + 1))
    continue
  fi

  # Step failed — interactive recovery
  if recover "${ALL_STEPS[$i]}"; then
    continue  # retry (don't advance i)
  else
    i=$((i + 1))  # skip (advance i)
  fi
done

# Done
echo ""
show_status
send_notification "SDLC complete" "All steps finished. Review retro in docs/retros/"
echo -e "${GREEN}${BOLD}SDLC complete.${NC} Review the retro in docs/retros/"
