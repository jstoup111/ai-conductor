#!/usr/bin/env bash
set -euo pipefail

# install — Installs the harness skills and conduct script for use with Claude Code.
#
# Usage:
#   ./bin/install          # Install everything
#   ./bin/install --check  # Check installation status without changing anything

HARNESS_DIR="$(cd "$(dirname "$0")/.." && pwd)"
SKILLS_DIR="${HOME}/.claude/skills"
LOCAL_BIN="${HOME}/.local/bin"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'
BOLD='\033[1m'

ok()   { echo -e "  ${GREEN}✓${NC} $*"; }
fail() { echo -e "  ${RED}✗${NC} $*"; }
warn() { echo -e "  ${YELLOW}⚠${NC} $*"; }
info() { echo -e "  ${CYAN}→${NC} $*"; }

SKILLS=(architecture-diagram architecture-review assess bootstrap brainstorm code-review conduct conflict-check debugging finish manual-test memory pipeline plan pr retro simplify stories tdd writing-system-tests)

# ─── Check Mode ───────────────────────────────────────────────────────────────

check_installation() {
  echo -e "${BOLD}Harness Installation Status${NC}"
  echo ""

  local all_ok=true

  # Check Claude Code
  if command -v claude &>/dev/null; then
    ok "Claude Code installed ($(claude --version 2>/dev/null || echo 'unknown version'))"
  else
    fail "Claude Code not found on PATH"
    all_ok=false
  fi

  # Check skills directory
  if [ -d "$SKILLS_DIR" ]; then
    ok "Skills directory exists ($SKILLS_DIR)"
  else
    fail "Skills directory missing ($SKILLS_DIR)"
    all_ok=false
  fi

  # Check each skill
  local missing=0
  local stale=0
  for skill in "${SKILLS[@]}"; do
    if [ -L "${SKILLS_DIR}/${skill}" ]; then
      local target
      target=$(readlink -f "${SKILLS_DIR}/${skill}" 2>/dev/null || echo "broken")
      if [ "$target" = "${HARNESS_DIR}/skills/${skill}" ]; then
        ok "Skill: ${skill}"
      else
        warn "Skill: ${skill} — points to ${target} (expected ${HARNESS_DIR}/skills/${skill})"
        stale=$((stale + 1))
      fi
    elif [ -d "${SKILLS_DIR}/${skill}" ]; then
      warn "Skill: ${skill} — exists but is not a symlink (may be a copy)"
      stale=$((stale + 1))
    else
      fail "Skill: ${skill} — not installed"
      missing=$((missing + 1))
    fi
  done

  # Check conduct script
  echo ""
  if command -v conduct &>/dev/null; then
    ok "conduct script on PATH ($(which conduct))"
  else
    fail "conduct script not on PATH"
    all_ok=false
  fi

  # Check dependencies
  echo ""
  if command -v glow &>/dev/null; then
    ok "glow installed (artifact review)"
  else
    warn "glow not installed — artifact review will use cat fallback"
  fi
  if command -v node &>/dev/null && npm list -g @modelcontextprotocol/server-puppeteer &>/dev/null; then
    ok "puppeteer MCP server installed"
  else
    warn "puppeteer MCP server not installed"
  fi
  if command -v rtk &>/dev/null; then
    ok "rtk installed (token usage reduction)"
  else
    warn "rtk not installed — token usage reduction unavailable"
  fi

  # Summary
  echo ""
  if [ "$missing" -eq 0 ] && [ "$stale" -eq 0 ] && $all_ok; then
    echo -e "${GREEN}${BOLD}All checks passed.${NC}"
  else
    [ "$missing" -gt 0 ] && echo -e "${RED}${missing} skill(s) missing.${NC}"
    [ "$stale" -gt 0 ] && echo -e "${YELLOW}${stale} skill(s) stale or misconfigured.${NC}"
    echo -e "Run ${BOLD}./bin/install${NC} to fix."
  fi
}

# ─── Permissions ──────────────────────────────────────────────────────────────

# Permissions the harness needs pre-approved to run without friction
HARNESS_PERMISSIONS=(
  # Read harness files (skills, agents, tech-context)
  "Read(${HARNESS_DIR}/**)"
  # Test runners
  "Bash(bundle exec rspec:*)"
  "Bash(bundle exec standardrb:*)"
  "Bash(bundle exec rails:*)"
  "Bash(bundle install:*)"
  # Project scaffolding
  "Bash(rails new:*)"
  "Bash(rails generate:*)"
  "Bash(docker compose:*)"
  # Git (non-destructive)
  "Bash(git init:*)"
  "Bash(git add:*)"
  "Bash(git commit:*)"
  "Bash(git status:*)"
  "Bash(git log:*)"
  "Bash(git diff:*)"
  "Bash(git branch:*)"
  "Bash(git checkout -b:*)"
  # GitHub (read-only)
  "Bash(gh pr list:*)"
  "Bash(gh issue list:*)"
)

configure_permissions() {
  local settings_file=$1

  # Write permissions list to a temp file for python to read
  local perms_file
  perms_file=$(mktemp)
  printf '%s\n' "${HARNESS_PERMISSIONS[@]}" > "$perms_file"

  local output
  output=$(python3 << PYEOF
import json, os

settings_path = "$settings_file"
perms_path = "$perms_file"

# Read desired permissions
with open(perms_path) as f:
    harness_perms = [line.strip() for line in f if line.strip()]

# Read or create settings
if os.path.exists(settings_path):
    with open(settings_path) as f:
        settings = json.load(f)
else:
    settings = {}

if "permissions" not in settings:
    settings["permissions"] = {}
if "allow" not in settings["permissions"]:
    settings["permissions"]["allow"] = []

existing = set(settings["permissions"]["allow"])
added = 0
for perm in harness_perms:
    if perm not in existing:
        settings["permissions"]["allow"].append(perm)
        added += 1

with open(settings_path, "w") as f:
    json.dump(settings, f, indent=2)
    f.write("\n")

print(f"{added} added, {len(harness_perms) - added} already set")
PYEOF
  )
  rm -f "$perms_file"

  if [ $? -eq 0 ]; then
    ok "Permissions: ${output}"
  else
    warn "Could not configure permissions automatically"
    info "Manually add harness read permissions to ${settings_file}"
  fi
}

# ─── Hooks ────────────────────────────────────────────────────────────────────

configure_hooks() {
  local settings_file=$1
  local hooks_dir="${HARNESS_DIR}/hooks/claude"

  local output
  output=$(python3 << PYEOF
import json, os

settings_path = "$settings_file"
hooks_dir = "$hooks_dir"

# Read existing settings
if os.path.exists(settings_path):
    with open(settings_path) as f:
        settings = json.load(f)
else:
    settings = {}

if "hooks" not in settings:
    settings["hooks"] = {}

# Define harness hooks
harness_hooks = {
    "PreToolUse": [
        {
            "matcher": "Bash",
            "hooks": [
                {
                    "type": "command",
                    "command": f"{hooks_dir}/block-destructive-git.sh",
                    "timeout": 10
                }
            ]
        },
        {
            "matcher": "Bash",
            "hooks": [
                {
                    "type": "command",
                    "command": f"{hooks_dir}/tdd-commit-gate.sh",
                    "timeout": 10
                }
            ]
        }
    ],
    "PostToolUse": [
        {
            "matcher": "Edit|Write",
            "hooks": [
                {
                    "type": "command",
                    "command": f"{hooks_dir}/lint-after-edit.sh",
                    "timeout": 30
                },
                {
                    "type": "command",
                    "command": f"{hooks_dir}/spec-coverage-check.sh",
                    "timeout": 10
                },
                {
                    "type": "command",
                    "command": f"{hooks_dir}/diagram-coverage-check.sh",
                    "timeout": 10
                }
            ]
        },
        {
            "matcher": "Bash",
            "hooks": [
                {
                    "type": "command",
                    "command": f"{hooks_dir}/post-commit-pipeline-sync.sh",
                    "timeout": 10
                }
            ]
        }
    ],
    "SessionStart": [
        {
            "hooks": [
                {
                    "type": "command",
                    "command": f"{hooks_dir}/session-start-context.sh",
                    "timeout": 15
                }
            ]
        }
    ],
    "Stop": [
        {
            "hooks": [
                {
                    "type": "command",
                    "command": f"{hooks_dir}/stop-memory-reminder.sh",
                    "timeout": 10
                }
            ]
        }
    ],
    "StopFailure": [
        {
            "matcher": "rate_limit",
            "hooks": [
                {
                    "type": "command",
                    "command": f"{hooks_dir}/rate-limit-wait.sh",
                    "timeout": 10
                }
            ]
        }
    ]
}

# Track what we add
added = 0
skipped = 0

for event, hook_entries in harness_hooks.items():
    if event not in settings["hooks"]:
        settings["hooks"][event] = []

    existing_commands = set()
    for entry in settings["hooks"][event]:
        for h in entry.get("hooks", []):
            existing_commands.add(h.get("command", ""))

    for entry in hook_entries:
        entry_commands = {h.get("command", "") for h in entry.get("hooks", [])}
        if entry_commands - existing_commands:
            settings["hooks"][event].append(entry)
            added += len(entry_commands - existing_commands)
        else:
            skipped += len(entry_commands)

with open(settings_path, "w") as f:
    json.dump(settings, f, indent=2)
    f.write("\n")

print(f"{added} added, {skipped} already set")
PYEOF
  )

  if [ $? -eq 0 ]; then
    ok "Hooks: ${output}"
  else
    warn "Could not configure hooks automatically"
    info "Manually add hooks to ${settings_file}"
  fi
}

# ─── Dependencies ────────────────────────────────────────────────────────────

install_dependencies() {
  echo ""
  echo -e "${BOLD}Dependencies${NC}"

  # glow — terminal markdown renderer (for artifact review in conduct)
  if command -v glow &>/dev/null; then
    ok "glow already installed"
  else
    info "Installing glow (terminal markdown renderer)..."
    local glow_installed=false
    if command -v brew &>/dev/null; then
      brew install glow 2>/dev/null && glow_installed=true
    fi
    if ! $glow_installed && command -v go &>/dev/null; then
      go install github.com/charmbracelet/glow@latest 2>/dev/null && glow_installed=true
    fi
    # Direct binary download (works on Linux/WSL when package managers aren't available)
    if ! $glow_installed; then
      local arch
      arch=$(uname -m)
      case "$arch" in
        x86_64)  arch="x86_64" ;;
        aarch64) arch="arm64" ;;
        *)       arch="" ;;
      esac
      if [ -n "$arch" ]; then
        local glow_ver="2.1.0"
        local glow_url="https://github.com/charmbracelet/glow/releases/download/v${glow_ver}/glow_${glow_ver}_Linux_${arch}.tar.gz"
        local glow_tmp="/tmp/glow-install-$$"
        mkdir -p "$glow_tmp"
        if curl -sL "$glow_url" -o "${glow_tmp}/glow.tar.gz" 2>/dev/null; then
          tar -xzf "${glow_tmp}/glow.tar.gz" -C "$glow_tmp" --strip-components=1 2>/dev/null
          if [ -f "${glow_tmp}/glow" ]; then
            mkdir -p "${HOME}/.local/bin"
            mv "${glow_tmp}/glow" "${HOME}/.local/bin/glow"
            chmod +x "${HOME}/.local/bin/glow"
            glow_installed=true
          fi
        fi
        rm -rf "$glow_tmp"
      fi
    fi
    if $glow_installed; then
      ok "glow installed"
    else
      warn "glow not installed — artifact review will use batcat/cat fallback"
      info "Install manually: https://github.com/charmbracelet/glow#installation"
    fi
  fi

  # rtk — reduces token usage in Claude Code sessions
  if command -v rtk &>/dev/null; then
    ok "rtk already installed"
  else
    info "Installing rtk (token usage reduction)..."
    local rtk_installed=false
    if command -v brew &>/dev/null; then
      brew install rtk 2>/dev/null && rtk_installed=true
    fi
    if ! $rtk_installed && command -v cargo &>/dev/null; then
      cargo install --git https://github.com/rtk-ai/rtk 2>/dev/null && rtk_installed=true
    fi
    # Fallback: official install script (installs to ~/.local/bin)
    if ! $rtk_installed; then
      if curl -fsSL https://raw.githubusercontent.com/rtk-ai/rtk/refs/heads/master/install.sh | sh 2>/dev/null; then
        rtk_installed=true
      fi
    fi
    if $rtk_installed; then
      ok "rtk installed"
    else
      warn "rtk not installed — install manually: https://github.com/rtk-ai/rtk"
    fi
  fi

  # @modelcontextprotocol/server-puppeteer — MCP server for browser automation
  if command -v node &>/dev/null; then
    if npm list -g @modelcontextprotocol/server-puppeteer &>/dev/null; then
      ok "puppeteer MCP server already installed"
    else
      info "Installing @modelcontextprotocol/server-puppeteer globally..."
      npm install -g @modelcontextprotocol/server-puppeteer 2>/dev/null && ok "puppeteer MCP server installed" || warn "puppeteer MCP install failed"
    fi
  else
    warn "Node.js not found — puppeteer MCP server not installed"
  fi
}

# ─── Install ──────────────────────────────────────────────────────────────────

install() {
  echo -e "${BOLD}${CYAN}Installing James Stoup Agents Harness${NC}"
  echo -e "  Source: ${HARNESS_DIR}"
  echo ""

  # 1. Ensure directories exist
  mkdir -p "$SKILLS_DIR"
  mkdir -p "$LOCAL_BIN"
  ok "Created directories"

  # 2. Symlink skills
  local installed=0
  local updated=0
  for skill in "${SKILLS[@]}"; do
    local source="${HARNESS_DIR}/skills/${skill}"
    local target="${SKILLS_DIR}/${skill}"

    if [ ! -d "$source" ]; then
      warn "Skill source missing: ${source} — skipping"
      continue
    fi

    if [ -L "$target" ]; then
      local current
      current=$(readlink -f "$target" 2>/dev/null || echo "")
      if [ "$current" = "$source" ]; then
        continue  # Already correct
      fi
      # Update stale symlink
      ln -sfn "$source" "$target"
      updated=$((updated + 1))
    else
      if [ -e "$target" ]; then
        warn "Skill: ${skill} — exists but is not a symlink. Backing up to ${target}.bak"
        mv "$target" "${target}.bak"
      fi
      ln -sfn "$source" "$target"
      installed=$((installed + 1))
    fi
  done

  if [ "$installed" -gt 0 ] || [ "$updated" -gt 0 ]; then
    ok "Skills: ${installed} installed, ${updated} updated (${#SKILLS[@]} total)"
  else
    ok "Skills: all ${#SKILLS[@]} already current"
  fi

  # 3. Symlink conduct script
  local conduct_source="${HARNESS_DIR}/bin/conduct"
  local conduct_target="${LOCAL_BIN}/conduct"

  if [ -L "$conduct_target" ]; then
    local current
    current=$(readlink -f "$conduct_target" 2>/dev/null || echo "")
    if [ "$current" != "$conduct_source" ]; then
      ln -sfn "$conduct_source" "$conduct_target"
      ok "Updated conduct script symlink"
    else
      ok "conduct script already current"
    fi
  else
    ln -sfn "$conduct_source" "$conduct_target"
    ok "Installed conduct script to ${conduct_target}"
  fi

  # 4. Configure Claude Code permissions and hooks
  local settings_file="${HOME}/.claude/settings.json"
  configure_permissions "$settings_file"
  configure_hooks "$settings_file"

  # 5. Check PATH
  if echo "$PATH" | tr ':' '\n' | grep -q "\.local/bin"; then
    ok "~/.local/bin is on PATH"
  else
    warn "~/.local/bin is NOT on PATH"
    info "Add to your shell profile: export PATH=\"\$HOME/.local/bin:\$PATH\""
  fi

  # 6. Install dependencies
  install_dependencies

  # 7. Check Claude Code
  if command -v claude &>/dev/null; then
    ok "Claude Code found"
  else
    warn "Claude Code not found — install from https://docs.anthropic.com/en/.docs/claude-code"
  fi

  echo ""
  echo -e "${GREEN}${BOLD}Installation complete.${NC}"
  echo ""
  echo -e "  ${BOLD}Quick start:${NC}"
  echo -e "    cd your-project/"
  echo -e "    claude                        # Start Claude Code"
  echo -e "    /conduct                      # Follow the SDLC flow"
  echo ""
  echo -e "  ${BOLD}Or automated:${NC}"
  echo -e "    cd your-project/"
  echo -e "    conduct \"your feature description\""
  echo ""
  echo -e "  ${BOLD}Verify:${NC}"
  echo -e "    ./bin/install --check"
}

# ─── Uninstall ────────────────────────────────────────────────────────────────

uninstall() {
  echo -e "${BOLD}${CYAN}Uninstalling James Stoup Agents Harness${NC}"
  echo ""

  local removed=0
  for skill in "${SKILLS[@]}"; do
    local target="${SKILLS_DIR}/${skill}"
    if [ -L "$target" ]; then
      local points_to
      points_to=$(readlink -f "$target" 2>/dev/null || echo "")
      if [[ "$points_to" == "${HARNESS_DIR}"* ]]; then
        rm "$target"
        removed=$((removed + 1))
      else
        warn "Skill: ${skill} — symlink points elsewhere, skipping"
      fi
    fi
  done
  ok "Removed ${removed} skill symlinks"

  if [ -L "${LOCAL_BIN}/conduct" ]; then
    rm "${LOCAL_BIN}/conduct"
    ok "Removed conduct script"
  fi

  echo ""
  echo -e "${GREEN}${BOLD}Uninstall complete.${NC}"
}

# ─── Main ─────────────────────────────────────────────────────────────────────

case "${1:-}" in
  --check)     check_installation ;;
  --uninstall) uninstall ;;
  -h|--help)
    echo "Usage: ./bin/install [--check | --uninstall | -h]"
    echo ""
    echo "  (no args)     Install/update harness skills and conduct script"
    echo "  --check       Check installation status"
    echo "  --uninstall   Remove all symlinks"
    echo "  -h, --help    Show this help"
    ;;
  *)           install ;;
esac
