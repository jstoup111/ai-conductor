#!/usr/bin/env bash
set -euo pipefail

# install — Installs the harness skills and conduct script for use with Claude Code.
#
# Usage:
#   ./bin/install          # Install everything
#   ./bin/install --check  # Check installation status without changing anything

HARNESS_DIR="$(cd "$(dirname "$0")/.." && pwd)"
SKILLS_DIR="${HOME}/.claude/skills"
LOCAL_BIN="${HOME}/.local/bin"
CONDUCTOR_CONFIG="${HOME}/.claude/ai-conductor.config.json"
HARNESS_USER_CONFIG="${HOME}/.ai-conductor/config.yml"

# UPDATE_MODE=true skips first-run-only work (dependency bootstrap, channel
# prompt). Set via the --update flag; used by bin/migrate after an accepted
# harness update.
UPDATE_MODE=false

# ALLOW_WORKTREE_ROOT=true bypasses the worktree-root guard (issue #363). Set
# via the --allow-worktree-root flag, which is stripped from "$@" before the
# mode dispatch so it composes with any mode (e.g. --update).
ALLOW_WORKTREE_ROOT=false

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'
BOLD='\033[1m'

ok()   { echo -e "  ${GREEN}✓${NC} $*"; }
fail() { echo -e "  ${RED}✗${NC} $*"; }
warn() { echo -e "  ${YELLOW}⚠${NC} $*"; }
info() { echo -e "  ${CYAN}→${NC} $*"; }

# Auto-discover every skill: any skills/<name>/ directory containing a SKILL.md.
# Previously this was a hardcoded list that drifted out of sync — new skills
# (engineer, prd-audit, …) were added to skills/ but forgotten here, so they were
# never symlinked into ~/.claude/skills/. Enumerating the directory guarantees ALL
# skills link. Glob results are alphabetically sorted by bash (deterministic order).
SKILLS=()
for _skill_dir in "${HARNESS_DIR}"/skills/*/; do
  [ -f "${_skill_dir}SKILL.md" ] || continue
  SKILLS+=("$(basename "$_skill_dir")")
done
unset _skill_dir
if [ ${#SKILLS[@]} -eq 0 ]; then
  fail "No skills found under ${HARNESS_DIR}/skills/ — is the harness checkout intact?"
  exit 1
fi

# ─── Worktree-root guard (issue #363) ─────────────────────────────────────────

# Refuse global-mutating installs when this checkout is a build worktree.
# A daemon self-build once ran `bin/install --update` rooted at a worktree:
# every global bin/skill symlink and settings.json hook path was repointed at
# a directory that ship-time worktree removal then deleted, bricking the
# operator environment. The guard keys on the PHYSICAL path (pwd -P) so a
# symlinked logical path cannot hide the `.worktrees` segment. Read-only modes
# (--check, --help) and --uninstall never call this.
guard_worktree_root() {
  if [ "$ALLOW_WORKTREE_ROOT" = true ]; then
    return 0
  fi
  local physical_root
  physical_root="$(cd "$HARNESS_DIR" && pwd -P)"
  case "$physical_root" in
    */.worktrees/*)
      fail "Refusing to install from a build worktree."
      echo ""
      echo "  Resolved harness root: ${physical_root}"
      echo ""
      echo "  Installing from a worktree would repoint your global bins, skills, and"
      echo "  settings.json hooks at a directory that is deleted when the build ships."
      echo ""
      echo "  Fix: run bin/install from the main checkout, or pass --allow-worktree-root"
      echo "  if you really mean to install from this worktree."
      exit 1
      ;;
  esac
}

# ─── Check Mode ───────────────────────────────────────────────────────────────

check_installation() {
  echo -e "${BOLD}Harness Installation Status${NC}"
  echo ""

  local all_ok=true

  # Check Claude Code
  if command -v claude &>/dev/null; then
    ok "Claude Code installed ($(claude --version 2>/dev/null || echo 'unknown version'))"
  else
    fail "Claude Code not found on PATH"
    all_ok=false
  fi

  # Check skills directory
  if [ -d "$SKILLS_DIR" ]; then
    ok "Skills directory exists ($SKILLS_DIR)"
  else
    fail "Skills directory missing ($SKILLS_DIR)"
    all_ok=false
  fi

  # Check each skill
  local missing=0
  local stale=0
  for skill in "${SKILLS[@]}"; do
    if [ -L "${SKILLS_DIR}/${skill}" ]; then
      local target
      target=$(readlink -f "${SKILLS_DIR}/${skill}" 2>/dev/null || echo "broken")
      if [ "$target" = "${HARNESS_DIR}/skills/${skill}" ]; then
        ok "Skill: ${skill}"
      else
        warn "Skill: ${skill} — points to ${target} (expected ${HARNESS_DIR}/skills/${skill})"
        stale=$((stale + 1))
      fi
    elif [ -d "${SKILLS_DIR}/${skill}" ]; then
      warn "Skill: ${skill} — exists but is not a symlink (may be a copy)"
      stale=$((stale + 1))
    else
      fail "Skill: ${skill} — not installed"
      missing=$((missing + 1))
    fi
  done

  # Check conduct script
  echo ""
  if command -v conduct &>/dev/null; then
    ok "conduct script on PATH ($(which conduct))"
  else
    fail "conduct script not on PATH"
    all_ok=false
  fi

  # Check conduct-ts (TypeScript conductor). The bundle is built from
  # src/conductor/ by bin/install; report whether it's built and on PATH.
  if [ -f "${HARNESS_DIR}/src/conductor/dist/index.js" ]; then
    if command -v conduct-ts &>/dev/null; then
      ok "conduct-ts built and on PATH ($(which conduct-ts))"
    else
      warn "conduct-ts bundle built but not on PATH — run ./bin/install"
    fi
  else
    warn "conduct-ts bundle not built — run ./bin/install (needs Node >=20.5)"
  fi

  # Check dependencies
  echo ""
  if [ -f "$HARNESS_USER_CONFIG" ] && grep -q "^markdown_viewer:" "$HARNESS_USER_CONFIG" 2>/dev/null; then
    local mv_cmd
    mv_cmd=$(python3 -c "import yaml,sys; c=yaml.safe_load(open('$HARNESS_USER_CONFIG')) or {}; print((c.get('markdown_viewer') or {}).get('command',''))" 2>/dev/null)
    if [ -n "$mv_cmd" ] && command -v "$mv_cmd" &>/dev/null; then
      ok "markdown viewer: ${mv_cmd} (artifact review)"
    else
      warn "markdown viewer '${mv_cmd:-unset}' configured but not on PATH — will fall back to cat"
    fi
  else
    warn "markdown viewer not configured — run ./bin/install to select one"
  fi
  if [ -f "$HARNESS_USER_CONFIG" ] && grep -q "^mermaid_renderer:" "$HARNESS_USER_CONFIG" 2>/dev/null; then
    local mr_preset mr_cmd
    mr_preset=$(python3 -c "import yaml; c=yaml.safe_load(open('$HARNESS_USER_CONFIG')) or {}; print((c.get('mermaid_renderer') or {}).get('preset',''))" 2>/dev/null)
    mr_cmd=$(python3 -c "import yaml; c=yaml.safe_load(open('$HARNESS_USER_CONFIG')) or {}; print((c.get('mermaid_renderer') or {}).get('command',''))" 2>/dev/null)
    if [ -z "$mr_cmd" ] || command -v "$mr_cmd" &>/dev/null; then
      ok "mermaid renderer: ${mr_preset:-unset} (diagram approval gates)"
    else
      warn "mermaid renderer '${mr_preset}' configured but '${mr_cmd}' not on PATH — diagrams fall back to raw Markdown"
    fi
  else
    warn "mermaid renderer not configured — run ./bin/install to select one"
  fi
  if command -v node &>/dev/null && npm list -g @modelcontextprotocol/server-puppeteer &>/dev/null; then
    ok "puppeteer MCP server installed"
  else
    warn "puppeteer MCP server not installed"
  fi
  if command -v rtk &>/dev/null; then
    ok "rtk installed (token usage reduction)"
    if [ -f "${HOME}/.claude/hooks/rtk-rewrite.sh" ]; then
      ok "rtk hook initialized"
    else
      warn "rtk installed but not initialized — run ./bin/install or 'rtk init -g'"
    fi
  else
    warn "rtk not installed — token usage reduction unavailable"
  fi

  # Summary. Return non-zero on ANY drift so `--check` is scriptable — callers
  # (e.g. the conduct-ts install-freshness guard) gate on the exit code.
  echo ""
  if [ "$missing" -eq 0 ] && [ "$stale" -eq 0 ] && $all_ok; then
    echo -e "${GREEN}${BOLD}All checks passed.${NC}"
    return 0
  else
    [ "$missing" -gt 0 ] && echo -e "${RED}${missing} skill(s) missing.${NC}"
    [ "$stale" -gt 0 ] && echo -e "${YELLOW}${stale} skill(s) stale or misconfigured.${NC}"
    echo -e "Run ${BOLD}./bin/install${NC} to fix."
    return 1
  fi
}

# ─── Permissions ──────────────────────────────────────────────────────────────

# Permissions the harness needs pre-approved to run without friction
HARNESS_PERMISSIONS=(
  # Read harness files (skills, agents, tech-context)
  "Read(${HARNESS_DIR}/**)"
  # Test runners
  "Bash(bundle exec rspec:*)"
  "Bash(bundle exec standardrb:*)"
  "Bash(bundle exec rails:*)"
  "Bash(bundle install:*)"
  # Project scaffolding
  "Bash(rails new:*)"
  "Bash(rails generate:*)"
  "Bash(docker compose:*)"
  # Git (non-destructive)
  "Bash(git init:*)"
  "Bash(git add:*)"
  "Bash(git commit:*)"
  "Bash(git status:*)"
  "Bash(git log:*)"
  "Bash(git diff:*)"
  "Bash(git branch:*)"
  "Bash(git checkout -b:*)"
  # GitHub (read-only)
  "Bash(gh pr list:*)"
  "Bash(gh issue list:*)"
)

configure_permissions() {
  local settings_file=$1

  # Write permissions list to a temp file for python to read
  local perms_file
  perms_file=$(mktemp)
  printf '%s\n' "${HARNESS_PERMISSIONS[@]}" > "$perms_file"

  local output
  output=$(python3 << PYEOF
import json, os

settings_path = "$settings_file"
perms_path = "$perms_file"

# Read desired permissions
with open(perms_path) as f:
    harness_perms = [line.strip() for line in f if line.strip()]

# Read or create settings
if os.path.exists(settings_path):
    with open(settings_path) as f:
        settings = json.load(f)
else:
    settings = {}

if "permissions" not in settings:
    settings["permissions"] = {}
if "allow" not in settings["permissions"]:
    settings["permissions"]["allow"] = []

existing = set(settings["permissions"]["allow"])
added = 0
for perm in harness_perms:
    if perm not in existing:
        settings["permissions"]["allow"].append(perm)
        added += 1

with open(settings_path, "w") as f:
    json.dump(settings, f, indent=2)
    f.write("\n")

print(f"{added} added, {len(harness_perms) - added} already set")
PYEOF
  )
  rm -f "$perms_file"

  if [ $? -eq 0 ]; then
    ok "Permissions: ${output}"
  else
    warn "Could not configure permissions automatically"
    info "Manually add harness read permissions to ${settings_file}"
  fi
}

# ─── Hooks ────────────────────────────────────────────────────────────────────

configure_hooks() {
  local settings_file=$1
  local hooks_dir="${HARNESS_DIR}/hooks/claude"

  local output
  output=$(python3 << PYEOF
import json, os

settings_path = "$settings_file"
hooks_dir = "$hooks_dir"

# Read existing settings
if os.path.exists(settings_path):
    with open(settings_path) as f:
        settings = json.load(f)
else:
    settings = {}

if "hooks" not in settings:
    settings["hooks"] = {}

# Define harness hooks
harness_hooks = {
    "PreToolUse": [
        {
            "matcher": "Bash",
            "hooks": [
                {
                    "type": "command",
                    "command": f"{hooks_dir}/block-destructive-git.sh",
                    "timeout": 10
                }
            ]
        },
        {
            "matcher": "Bash",
            "hooks": [
                {
                    "type": "command",
                    "command": f"{hooks_dir}/tdd-commit-gate.sh",
                    "timeout": 10
                }
            ]
        }
    ],
    "PostToolUse": [
        {
            "matcher": "Edit|Write",
            "hooks": [
                {
                    "type": "command",
                    "command": f"{hooks_dir}/lint-after-edit.sh",
                    "timeout": 30
                },
                {
                    "type": "command",
                    "command": f"{hooks_dir}/spec-coverage-check.sh",
                    "timeout": 10
                },
                {
                    "type": "command",
                    "command": f"{hooks_dir}/diagram-coverage-check.sh",
                    "timeout": 10
                }
            ]
        },
        {
            "matcher": "Bash",
            "hooks": [
                {
                    "type": "command",
                    "command": f"{hooks_dir}/post-commit-pipeline-sync.sh",
                    "timeout": 10
                }
            ]
        }
    ],
    "SessionStart": [
        {
            "hooks": [
                {
                    "type": "command",
                    "command": f"{hooks_dir}/session-start-context.sh",
                    "timeout": 15
                }
            ]
        }
    ],
    "Stop": [
        {
            "hooks": [
                {
                    "type": "command",
                    "command": f"{hooks_dir}/stop-memory-reminder.sh",
                    "timeout": 10
                }
            ]
        }
    ],
    "StopFailure": [
        {
            "matcher": "rate_limit",
            "hooks": [
                {
                    "type": "command",
                    "command": f"{hooks_dir}/rate-limit-wait.sh",
                    "timeout": 10
                }
            ]
        }
    ]
}

# Track what we add
added = 0
skipped = 0

for event, hook_entries in harness_hooks.items():
    if event not in settings["hooks"]:
        settings["hooks"][event] = []

    existing_commands = set()
    for entry in settings["hooks"][event]:
        for h in entry.get("hooks", []):
            existing_commands.add(h.get("command", ""))

    for entry in hook_entries:
        entry_commands = {h.get("command", "") for h in entry.get("hooks", [])}
        if entry_commands - existing_commands:
            settings["hooks"][event].append(entry)
            added += len(entry_commands - existing_commands)
        else:
            skipped += len(entry_commands)

with open(settings_path, "w") as f:
    json.dump(settings, f, indent=2)
    f.write("\n")

print(f"{added} added, {skipped} already set")
PYEOF
  )

  if [ $? -eq 0 ]; then
    ok "Hooks: ${output}"
  else
    warn "Could not configure hooks automatically"
    info "Manually add hooks to ${settings_file}"
  fi
}

# ─── Dependencies ────────────────────────────────────────────────────────────

install_dependencies() {
  echo ""
  echo -e "${BOLD}Dependencies${NC}"

  # Markdown viewer — handled by configure_md_viewer (below). Earlier versions
  # hard-installed glow here; the viewer is now user-selectable and installed
  # on-demand inside configure_md_viewer.

  # rtk — reduces token usage in Claude Code sessions
  if command -v rtk &>/dev/null; then
    ok "rtk already installed"
  else
    info "Installing rtk (token usage reduction)..."
    local rtk_installed=false
    if command -v brew &>/dev/null; then
      brew install rtk 2>/dev/null && rtk_installed=true
    fi
    if ! $rtk_installed && command -v cargo &>/dev/null; then
      cargo install --git https://github.com/rtk-ai/rtk 2>/dev/null && rtk_installed=true
    fi
    # Fallback: official install script (installs to ~/.local/bin)
    if ! $rtk_installed; then
      if curl -fsSL https://raw.githubusercontent.com/rtk-ai/rtk/refs/heads/master/install.sh | sh 2>/dev/null; then
        rtk_installed=true
      fi
    fi
    if $rtk_installed; then
      ok "rtk installed"
    else
      warn "rtk not installed — install manually: https://github.com/rtk-ai/rtk"
    fi
  fi

  # rtk init — install Claude Code hook for transparent command rewriting
  if command -v rtk &>/dev/null; then
    if [ -f "${HOME}/.claude/hooks/rtk-rewrite.sh" ]; then
      ok "rtk hook already initialized"
    else
      info "Initializing rtk for Claude Code..."
      if rtk init -g --auto-patch 2>/dev/null; then
        ok "rtk initialized (restart Claude Code to activate)"
      else
        warn "rtk init failed — run 'rtk init -g' manually"
      fi
    fi
  fi

  # @modelcontextprotocol/server-puppeteer — MCP server for browser automation
  if command -v node &>/dev/null; then
    if npm list -g @modelcontextprotocol/server-puppeteer &>/dev/null; then
      ok "puppeteer MCP server already installed"
    else
      info "Installing @modelcontextprotocol/server-puppeteer globally..."
      npm install -g @modelcontextprotocol/server-puppeteer 2>/dev/null && ok "puppeteer MCP server installed" || warn "puppeteer MCP install failed"
    fi
  else
    warn "Node.js not found — puppeteer MCP server not installed"
  fi

  # Serena — optional LSP-backed semantic code toolkit (oraios/serena), used as an
  # MCP server. Opt-in: heavyweight, so we prompt rather than auto-install like rtk.
  # /bootstrap auto-registers it as a user-scope MCP server once it's on PATH.
  if command -v serena &>/dev/null; then
    ok "Serena already installed"
  elif ! command -v uv &>/dev/null; then
    warn "Serena not installed — needs uv (https://docs.astral.sh/uv/), then: uv tool install -p 3.13 serena-agent"
  elif [ ! -t 0 ]; then
    info "Serena available (oraios/serena) — install later with: uv tool install -p 3.13 serena-agent"
  else
    printf "  ${CYAN}→${NC} Install Serena semantic code toolkit (oraios/serena)? [y/N]: "
    read -r serena_choice
    if [[ "$serena_choice" =~ ^[Yy]$ ]]; then
      info "Installing Serena via uv..."
      if uv tool install -p 3.13 serena-agent 2>/dev/null; then
        ok "Serena installed — /bootstrap will register it as an MCP server"
      else
        warn "Serena install failed — retry manually: uv tool install -p 3.13 serena-agent"
      fi
    else
      info "Skipped — install later with: uv tool install -p 3.13 serena-agent"
    fi
  fi
}

# ─── Markdown viewer config ───────────────────────────────────────────────────

# Preset table parallels src/conductor/src/engine/md-viewer-presets.ts.
# Keep in sync if you add/remove presets on either side.
# Columns: key | label | command | args | mode
MD_VIEWER_PRESETS=(
  "glow|glow       (terminal, paged)|glow|-p -w 80 {file}|inline"
  "bat|bat        (terminal, syntax-highlighted)|bat|--style=plain --paging=never {file}|inline"
  "mdcat|mdcat      (terminal)|mdcat|{file}|inline"
  "code|VSCode     (GUI, code --wait)|code|--wait {file}|blocking"
  "typora|Typora     (GUI)|typora|--wait {file}|blocking"
  "marktext|MarkText   (GUI)|marktext|{file}|external"
  "nvim|neovim     (terminal editor)|nvim|{file}|blocking"
  "obsidian|Obsidian   (GUI)|obsidian|{file}|external"
  "cat|cat        (universal fallback)|cat|{file}|inline"
)

# Mermaid renderer preset catalog — parallels MERMAID_RENDERER_PRESETS in
# src/conductor/src/engine/mermaid-renderer-presets.ts. Keep in sync.
# Columns: key | label | command | args | mode  (command empty = no tool needed)
MERMAID_RENDERER_PRESETS=(
  "html|HTML preview (browser, no native deps — works anywhere)||{file}|external"
  "mmdc-png|PNG images (mermaid-cli, needs Chromium)|mmdc|-i {file} -o {out}|external"
  "mmdc-svg|SVG images (mermaid-cli, needs Chromium)|mmdc|-i {file} -o {out}|external"
  "none|disabled (raw Markdown)||{file}|external"
)

# Try to install one of the terminal viewers via common package managers.
# Silent best-effort; returns 0 if installed or already present, 1 otherwise.
install_md_viewer_tool() {
  local tool=$1
  command -v "$tool" &>/dev/null && return 0
  case "$tool" in
    glow)
      if command -v brew &>/dev/null; then
        brew install glow &>/dev/null && return 0
      fi
      if command -v go &>/dev/null; then
        go install github.com/charmbracelet/glow@latest &>/dev/null && return 0
      fi
      local arch
      arch=$(uname -m)
      case "$arch" in
        x86_64)  arch="x86_64" ;;
        aarch64) arch="arm64" ;;
        *)       return 1 ;;
      esac
      local glow_ver="2.1.0"
      local glow_url="https://github.com/charmbracelet/glow/releases/download/v${glow_ver}/glow_${glow_ver}_Linux_${arch}.tar.gz"
      local glow_tmp="/tmp/glow-install-$$"
      mkdir -p "$glow_tmp"
      if curl -sL "$glow_url" -o "${glow_tmp}/glow.tar.gz" 2>/dev/null; then
        tar -xzf "${glow_tmp}/glow.tar.gz" -C "$glow_tmp" --strip-components=1 2>/dev/null
        if [ -f "${glow_tmp}/glow" ]; then
          mkdir -p "${HOME}/.local/bin"
          mv "${glow_tmp}/glow" "${HOME}/.local/bin/glow"
          chmod +x "${HOME}/.local/bin/glow"
          rm -rf "$glow_tmp"
          return 0
        fi
      fi
      rm -rf "$glow_tmp"
      return 1
      ;;
    bat)
      if command -v brew &>/dev/null; then
        brew install bat &>/dev/null && return 0
      fi
      if command -v apt-get &>/dev/null; then
        sudo apt-get install -y bat &>/dev/null && return 0
      fi
      return 1
      ;;
    mdcat)
      if command -v brew &>/dev/null; then
        brew install mdcat &>/dev/null && return 0
      fi
      if command -v cargo &>/dev/null; then
        cargo install mdcat &>/dev/null && return 0
      fi
      return 1
      ;;
    *)
      return 1
      ;;
  esac
}

# Persist the chosen viewer to ~/.ai-conductor/config.yml. Uses Python+yaml
# so existing keys (e.g. conductor.*) are preserved.
# Install the tool a mermaid preset needs. html/none need no tool. mmdc-* need
# @mermaid-js/mermaid-cli via npm (only if node is present). Silent best-effort;
# returns 0 if present/installed or no tool needed, 1 otherwise.
install_mermaid_tool() {
  local key=$1
  case "$key" in
    html|none)
      return 0
      ;;
    mmdc-png|mmdc-svg)
      command -v mmdc &>/dev/null && return 0
      if command -v npm &>/dev/null; then
        npm install -g @mermaid-js/mermaid-cli &>/dev/null && return 0
      fi
      return 1
      ;;
    *)
      return 1
      ;;
  esac
}

write_md_viewer_config() {
  local preset=$1 cmd=$2 args=$3 mode=$4
  mkdir -p "$(dirname "$HARNESS_USER_CONFIG")"
  CFG_PATH="$HARNESS_USER_CONFIG" PRESET="$preset" CMD="$cmd" ARGS="$args" MODE="$mode" python3 - <<'PY'
import os, yaml
from pathlib import Path
p = Path(os.environ["CFG_PATH"])
try:
    cfg = yaml.safe_load(p.read_text()) if p.exists() else {}
except Exception:
    cfg = {}
if cfg is None:
    cfg = {}
cfg["markdown_viewer"] = {
    "preset": os.environ["PRESET"],
    "command": os.environ["CMD"],
    "args": os.environ["ARGS"].split(),
    "mode": os.environ["MODE"],
}
p.parent.mkdir(parents=True, exist_ok=True)
p.write_text(yaml.safe_dump(cfg, sort_keys=False, default_flow_style=False))
PY
}

# Prompt the user for a markdown viewer preset, probe PATH for availability,
# optionally install the chosen terminal tool, and persist the selection.
# Skipped entirely in --update mode (leaves any existing selection alone).
configure_md_viewer() {
  # Skip in non-interactive or update-mode runs. Emit a nudge if nothing is
  # configured yet so users know how to set it later.
  if [ "$UPDATE_MODE" = true ] || [ ! -t 0 ]; then
    if ! grep -q "^markdown_viewer:" "$HARNESS_USER_CONFIG" 2>/dev/null; then
      info "markdown viewer not configured — run bin/install (no flags) or edit $HARNESS_USER_CONFIG"
    fi
    return 0
  fi

  echo ""
  info "Markdown viewer — how should /conduct display artifacts for review?"
  echo "    [*] = installed and on PATH"
  echo ""
  local i=1
  local -a preset_keys=()
  local default_idx=""
  local entry key label cmd args mode marker
  for entry in "${MD_VIEWER_PRESETS[@]}"; do
    IFS='|' read -r key label cmd args mode <<< "$entry"
    preset_keys+=("$entry")
    if command -v "$cmd" &>/dev/null; then
      marker=" [*]"
      [ -z "$default_idx" ] && default_idx=$i
    else
      marker=""
    fi
    printf "    %d) %s%s\n" "$i" "$label" "$marker"
    i=$((i + 1))
  done
  printf "    %d) Custom    (enter a command)\n" "$i"
  [ -z "$default_idx" ] && default_idx=1

  local choice
  read -r -p "  Choice [${default_idx}]: " choice
  choice=${choice:-$default_idx}

  if [ "$choice" = "$i" ]; then
    # Custom preset — ask for everything.
    local c_cmd c_args c_mode
    read -r -p "    command (e.g. glow, code, obsidian): " c_cmd
    read -r -p "    args (must include {file}) [${c_cmd} {file}]: " c_args
    c_args=${c_args:-"{file}"}
    read -r -p "    mode (inline|blocking|external) [inline]: " c_mode
    c_mode=${c_mode:-inline}
    case "$c_mode" in
      inline|blocking|external) ;;
      *) warn "invalid mode '${c_mode}' — defaulting to inline"; c_mode=inline ;;
    esac
    if [[ "$c_args" != *"{file}"* ]]; then
      warn "args must contain {file} — appending"
      c_args="${c_args} {file}"
    fi
    write_md_viewer_config "custom" "$c_cmd" "$c_args" "$c_mode"
    ok "Markdown viewer: custom (${c_cmd})"
    return 0
  fi

  if ! [[ "$choice" =~ ^[0-9]+$ ]] || [ "$choice" -lt 1 ] || [ "$choice" -ge "$i" ]; then
    warn "invalid choice '${choice}' — defaulting to preset ${default_idx}"
    choice=$default_idx
  fi

  IFS='|' read -r key label cmd args mode <<< "${preset_keys[$((choice - 1))]}"

  if ! command -v "$cmd" &>/dev/null; then
    info "Trying to install ${key}..."
    if install_md_viewer_tool "$key"; then
      ok "${key} installed"
    else
      warn "${key} not installed automatically — the viewer will fall back to cat until you install it"
      info "Install manually, then re-run bin/install"
    fi
  fi

  write_md_viewer_config "$key" "$cmd" "$args" "$mode"
  ok "Markdown viewer: ${key} (${mode})"
}

write_mermaid_renderer_config() {
  local preset=$1 cmd=$2 args=$3 mode=$4
  mkdir -p "$(dirname "$HARNESS_USER_CONFIG")"
  CFG_PATH="$HARNESS_USER_CONFIG" PRESET="$preset" CMD="$cmd" ARGS="$args" MODE="$mode" python3 - <<'PY'
import os, yaml
from pathlib import Path
p = Path(os.environ["CFG_PATH"])
try:
    cfg = yaml.safe_load(p.read_text()) if p.exists() else {}
except Exception:
    cfg = {}
if cfg is None:
    cfg = {}
cfg["mermaid_renderer"] = {
    "preset": os.environ["PRESET"],
    "command": os.environ["CMD"],
    "args": os.environ["ARGS"].split(),
    "mode": os.environ["MODE"],
}
p.parent.mkdir(parents=True, exist_ok=True)
p.write_text(yaml.safe_dump(cfg, sort_keys=False, default_flow_style=False))
PY
}

# Prompt the user for a mermaid renderer preset, probe availability, optionally
# install the chosen tool, and persist the selection. Parallels configure_md_viewer.
# html/none need no tool (always available); mmdc-* need @mermaid-js/mermaid-cli.
# Skipped in --update / non-interactive runs (leaves any existing selection alone).
configure_mermaid_renderer() {
  if [ "$UPDATE_MODE" = true ] || [ ! -t 0 ]; then
    if ! grep -q "^mermaid_renderer:" "$HARNESS_USER_CONFIG" 2>/dev/null; then
      info "mermaid renderer not configured — run bin/install (no flags) or edit $HARNESS_USER_CONFIG"
    fi
    return 0
  fi

  echo ""
  info "Mermaid renderer — how should /conduct show diagrams at the architecture approval gates?"
  echo "    [*] = available now (no tool needed, or tool on PATH)"
  echo ""
  local i=1
  local -a preset_keys=()
  local default_idx=""
  local entry key label cmd args mode marker
  for entry in "${MERMAID_RENDERER_PRESETS[@]}"; do
    IFS='|' read -r key label cmd args mode <<< "$entry"
    preset_keys+=("$entry")
    # A preset is available when it needs no tool (empty command) or its tool is on PATH.
    if [ -z "$cmd" ] || command -v "$cmd" &>/dev/null; then
      marker=" [*]"
      [ -z "$default_idx" ] && default_idx=$i
    else
      marker=""
    fi
    printf "    %d) %s%s\n" "$i" "$label" "$marker"
    i=$((i + 1))
  done
  [ -z "$default_idx" ] && default_idx=1

  local choice
  read -r -p "  Choice [${default_idx}]: " choice
  choice=${choice:-$default_idx}

  if ! [[ "$choice" =~ ^[0-9]+$ ]] || [ "$choice" -lt 1 ] || [ "$choice" -ge "$i" ]; then
    warn "invalid choice '${choice}' — defaulting to preset ${default_idx}"
    choice=$default_idx
  fi

  IFS='|' read -r key label cmd args mode <<< "${preset_keys[$((choice - 1))]}"

  if [ -n "$cmd" ] && ! command -v "$cmd" &>/dev/null; then
    info "Trying to install ${key} (${cmd})..."
    if install_mermaid_tool "$key"; then
      ok "${key} installed"
    else
      warn "${key} not installed automatically — diagrams will fall back to raw Markdown until you install it"
      info "Install manually (npm install -g @mermaid-js/mermaid-cli), then re-run bin/install"
    fi
  fi

  write_mermaid_renderer_config "$key" "$cmd" "$args" "$mode"
  ok "Mermaid renderer: ${key} (${mode})"
}

# ─── AI Conductor config (channel, current version) ──────────────────────────

# Detect the current harness version from git tag or VERSION file.
# Returns "vX.Y.Z" when on an exact tag, "vX.Y.Z" from VERSION as a fallback,
# or "main@<short-sha>" when on main.
detect_current_version() {
  local tag
  tag=$(git -C "$HARNESS_DIR" describe --tags --exact-match HEAD 2>/dev/null || echo "")
  if [ -n "$tag" ]; then
    echo "$tag"
    return 0
  fi
  if [ -f "${HARNESS_DIR}/VERSION" ]; then
    local v
    v=$(tr -d '[:space:]' < "${HARNESS_DIR}/VERSION")
    if [ -n "$v" ]; then
      echo "v$v"
      return 0
    fi
  fi
  local sha
  sha=$(git -C "$HARNESS_DIR" rev-parse --short HEAD 2>/dev/null || echo "unknown")
  echo "main@$sha"
}

# Create or refresh ~/.claude/ai-conductor.config.json.
# First run: prompt for channel (tagged vs main), write a new config with the
# current version. Update mode: refresh currentVersion only; preserve channel,
# autoCheck, and any other fields the user has set.
configure_conductor() {
  local detected
  detected=$(detect_current_version)
  local now
  now=$(date -u +%Y-%m-%dT%H:%M:%SZ)

  mkdir -p "$(dirname "$CONDUCTOR_CONFIG")"

  if [ ! -f "$CONDUCTOR_CONFIG" ]; then
    # First run — pick a channel.
    local channel="tagged"
    if [ "$UPDATE_MODE" != true ] && [ -t 0 ]; then
      echo ""
      info "Harness update channel — which version should /conduct follow?"
      echo "    1) tagged  — stable semver releases (recommended)"
      echo "    2) main    — bleeding edge, every merge to main"
      read -r -p "  Choice [1]: " choice
      case "$choice" in
        2) channel="main" ;;
        *) channel="tagged" ;;
      esac
    fi
    CFG_PATH="$CONDUCTOR_CONFIG" DETECTED="$detected" CHANNEL="$channel" NOW="$now" python3 -c '
import json, os
from pathlib import Path
cfg = {
    "updateChannel": os.environ["CHANNEL"],
    "autoCheck": True,
    "currentVersion": os.environ["DETECTED"],
    "lastCheckedAt": os.environ["NOW"],
}
Path(os.environ["CFG_PATH"]).write_text(json.dumps(cfg, indent=2) + "\n")
'
    ok "Created ${CONDUCTOR_CONFIG} (channel: ${channel}, version: ${detected})"
  else
    # Update — refresh currentVersion + lastCheckedAt, preserve everything else.
    CFG_PATH="$CONDUCTOR_CONFIG" DETECTED="$detected" NOW="$now" python3 -c '
import json, os
from pathlib import Path
p = Path(os.environ["CFG_PATH"])
try:
    cfg = json.loads(p.read_text())
except Exception:
    cfg = {}
cfg.setdefault("updateChannel", "tagged")
cfg.setdefault("autoCheck", True)
cfg["currentVersion"] = os.environ["DETECTED"]
cfg["lastCheckedAt"] = os.environ["NOW"]
p.write_text(json.dumps(cfg, indent=2) + "\n")
'
    ok "Refreshed ${CONDUCTOR_CONFIG} (version: ${detected})"
  fi
}

# ─── conduct-ts build ─────────────────────────────────────────────────────────

# Return 0 if the active Node satisfies conduct-ts's >=20.5 requirement (execa
# imports addAbortListener, added in Node 20.5). The repo pins 20.19.2 via
# .tool-versions. Returns 1 if Node is absent or too old.
node_supports_conduct_ts() {
  local node_v="" major=0 minor=0 rest=""
  node_v=$(node --version 2>/dev/null | sed 's/^v//') || true
  [ -z "$node_v" ] && return 1
  major=${node_v%%.*}
  rest=${node_v#*.}
  minor=${rest%%.*}
  [ "$major" -gt 20 ] || { [ "$major" -eq 20 ] && [ "$minor" -ge 5 ]; }
}

# Build the conduct-ts bundle: npm install + npm run build in src/conductor/.
# Runs in BOTH fresh-install and --update modes — the install-freshness guard
# refuses to start a stale bundle, so an update that skipped the rebuild would
# brick `conduct-ts`. Non-fatal: on any failure it warns and returns 1 so the
# caller can continue (step 3b then reports the missing bundle). Idempotent —
# npm install is a near no-op when dependencies are already satisfied.
build_conduct_ts() {
  local conductor_dir="${HARNESS_DIR}/src/conductor"
  echo ""
  echo -e "${BOLD}conduct-ts${NC}"

  if [ ! -f "${conductor_dir}/package.json" ]; then
    warn "src/conductor/package.json missing — skipping conduct-ts build"
    return 0
  fi

  if ! command -v npm &>/dev/null; then
    warn "npm not found — cannot build conduct-ts; skipping"
    info "Install Node >=20.5 + npm, then re-run bin/install"
    return 1
  fi

  if ! node_supports_conduct_ts; then
    warn "Node >=20.5 not active (repo pins 20.19.2 via .tool-versions) — skipping conduct-ts build"
    info "Install it (e.g. 'asdf install nodejs 20.19.2'), then re-run bin/install"
    return 1
  fi

  local log
  log=$(mktemp)

  info "Installing conduct-ts dependencies (npm install)..."
  if (cd "$conductor_dir" && npm install) >"$log" 2>&1; then
    ok "conduct-ts dependencies installed"
  else
    fail "npm install failed in src/conductor/ — conduct-ts not built"
    tail -n 20 "$log" | sed 's/^/      /'
    rm -f "$log"
    return 1
  fi

  info "Building conduct-ts bundle (npm run build)..."
  if (cd "$conductor_dir" && npm run build) >"$log" 2>&1; then
    ok "conduct-ts bundle built (src/conductor/dist/index.js)"
  else
    fail "npm run build failed in src/conductor/ — conduct-ts not built"
    tail -n 20 "$log" | sed 's/^/      /'
    rm -f "$log"
    return 1
  fi

  rm -f "$log"
  return 0
}

# ─── Install ──────────────────────────────────────────────────────────────────

install() {
  guard_worktree_root

  echo -e "${BOLD}${CYAN}Installing James Stoup Agents Harness${NC}"
  echo -e "  Source: ${HARNESS_DIR}"
  echo ""

  # 1. Ensure directories exist
  mkdir -p "$SKILLS_DIR"
  mkdir -p "$LOCAL_BIN"
  ok "Created directories"

  # 2. Symlink skills
  local installed=0
  local updated=0
  for skill in "${SKILLS[@]}"; do
    local source="${HARNESS_DIR}/skills/${skill}"
    local target="${SKILLS_DIR}/${skill}"

    if [ ! -d "$source" ]; then
      warn "Skill source missing: ${source} — skipping"
      continue
    fi

    if [ -L "$target" ]; then
      local current
      current=$(readlink -f "$target" 2>/dev/null || echo "")
      if [ "$current" = "$source" ]; then
        continue  # Already correct
      fi
      # Update stale symlink
      ln -sfn "$source" "$target"
      updated=$((updated + 1))
    else
      if [ -e "$target" ]; then
        warn "Skill: ${skill} — exists but is not a symlink. Backing up to ${target}.bak"
        mv "$target" "${target}.bak"
      fi
      ln -sfn "$source" "$target"
      installed=$((installed + 1))
    fi
  done

  if [ "$installed" -gt 0 ] || [ "$updated" -gt 0 ]; then
    ok "Skills: ${installed} installed, ${updated} updated (${#SKILLS[@]} total)"
  else
    ok "Skills: all ${#SKILLS[@]} already current"
  fi

  # 3. Symlink conduct script
  local conduct_source="${HARNESS_DIR}/bin/conduct"
  local conduct_target="${LOCAL_BIN}/conduct"

  if [ -L "$conduct_target" ]; then
    local current
    current=$(readlink -f "$conduct_target" 2>/dev/null || echo "")
    if [ "$current" != "$conduct_source" ]; then
      ln -sfn "$conduct_source" "$conduct_target"
      ok "Updated conduct script symlink"
    else
      ok "conduct script already current"
    fi
  else
    ln -sfn "$conduct_source" "$conduct_target"
    ok "Installed conduct script to ${conduct_target}"
  fi

  # 3a. Build conduct-ts (npm install + npm run build) so the dist bundle is
  # fresh before we symlink it. Runs in --update mode too — the install-freshness
  # guard refuses a stale bundle. Non-fatal: a build failure (no npm, wrong Node)
  # just leaves the bundle missing, and step 3b reports that.
  build_conduct_ts || true

  # 3b. Symlink conduct-ts (TypeScript conductor) if the dist bundle exists.
  # conduct-ts is the engine-layer rewrite of conduct; users opt in today by
  # invoking `conduct-ts` explicitly. The bundle is produced by
  # `npm run build` inside src/conductor/ (step 3a above); skip the symlink if
  # it's still missing (build skipped or failed).
  local conduct_ts_source="${HARNESS_DIR}/bin/conduct-ts"
  local conduct_ts_target="${LOCAL_BIN}/conduct-ts"
  local conduct_ts_dist="${HARNESS_DIR}/src/conductor/dist/index.js"

  if [ -f "$conduct_ts_dist" ]; then
    if [ -L "$conduct_ts_target" ]; then
      local current_ts
      current_ts=$(readlink -f "$conduct_ts_target" 2>/dev/null || echo "")
      if [ "$current_ts" != "$conduct_ts_source" ]; then
        ln -sfn "$conduct_ts_source" "$conduct_ts_target"
        ok "Updated conduct-ts script symlink"
      else
        ok "conduct-ts script already current"
      fi
    else
      ln -sfn "$conduct_ts_source" "$conduct_ts_target"
      ok "Installed conduct-ts script to ${conduct_ts_target}"
    fi
  else
    # Build (step 3a) was skipped or failed, so the bundle is absent. Surface the
    # real cause — conduct-ts needs Node >=20.5 (execa imports addAbortListener),
    # and the repo pins 20.19.2 via .tool-versions.
    if node_supports_conduct_ts; then
      info "conduct-ts bundle not found — 'npm run build' in src/conductor/ failed or was skipped; see the conduct-ts section above"
    else
      warn "conduct-ts bundle not found and Node >=20.5 is not active (the repo pins 20.19.2 via .tool-versions). Install it (e.g. 'asdf install nodejs 20.19.2'), then re-run bin/install."
    fi
  fi

  # 4. Configure Claude Code permissions and hooks
  local settings_file="${HOME}/.claude/settings.json"
  configure_permissions "$settings_file"
  configure_hooks "$settings_file"

  # 5. Check PATH
  if echo "$PATH" | tr ':' '\n' | grep -q "\.local/bin"; then
    ok "~/.local/bin is on PATH"
  else
    warn "~/.local/bin is NOT on PATH"
    info "Add to your shell profile: export PATH=\"\$HOME/.local/bin:\$PATH\""
  fi

  # 6. Install dependencies (skip in --update mode — one-time bootstrap only)
  if [ "$UPDATE_MODE" = true ]; then
    info "Update mode — skipping dependency bootstrap"
  else
    install_dependencies
  fi

  # 6b. Seed or refresh the AI-conductor config (channel prompt only on first run)
  configure_conductor

  # 6c. Prompt for a markdown viewer (skipped on --update)
  configure_md_viewer
  configure_mermaid_renderer

  # 7. Check Claude Code
  if command -v claude &>/dev/null; then
    ok "Claude Code found"
  else
    warn "Claude Code not found — install from https://docs.anthropic.com/en/.docs/claude-code"
  fi

  echo ""
  echo -e "${GREEN}${BOLD}Installation complete.${NC}"
  echo ""
  echo -e "  ${BOLD}Quick start:${NC}"
  echo -e "    cd your-project/"
  echo -e "    claude                        # Start Claude Code"
  echo -e "    /conduct                      # Follow the SDLC flow"
  echo ""
  echo -e "  ${BOLD}Or automated:${NC}"
  echo -e "    cd your-project/"
  echo -e "    conduct \"your feature description\""
  echo ""
  echo -e "  ${BOLD}Verify:${NC}"
  echo -e "    ./bin/install --check"
}

# ─── Uninstall ────────────────────────────────────────────────────────────────

uninstall() {
  echo -e "${BOLD}${CYAN}Uninstalling James Stoup Agents Harness${NC}"
  echo ""

  local removed=0
  for skill in "${SKILLS[@]}"; do
    local target="${SKILLS_DIR}/${skill}"
    if [ -L "$target" ]; then
      local points_to
      points_to=$(readlink -f "$target" 2>/dev/null || echo "")
      if [[ "$points_to" == "${HARNESS_DIR}"* ]]; then
        rm "$target"
        removed=$((removed + 1))
      else
        warn "Skill: ${skill} — symlink points elsewhere, skipping"
      fi
    fi
  done
  ok "Removed ${removed} skill symlinks"

  if [ -L "${LOCAL_BIN}/conduct" ]; then
    rm "${LOCAL_BIN}/conduct"
    ok "Removed conduct script"
  fi

  echo ""
  echo -e "${GREEN}${BOLD}Uninstall complete.${NC}"
}

# ─── Main ─────────────────────────────────────────────────────────────────────

# Strip --allow-worktree-root from "$@" before the mode dispatch so it can be
# combined with any mode (e.g. `--update --allow-worktree-root`).
_filtered_args=()
for _arg in "$@"; do
  if [ "$_arg" = "--allow-worktree-root" ]; then
    ALLOW_WORKTREE_ROOT=true
  else
    _filtered_args+=("$_arg")
  fi
done
set -- ${_filtered_args[@]+"${_filtered_args[@]}"}
unset _filtered_args _arg

case "${1:-}" in
  --check)     check_installation; exit $? ;;
  --uninstall) uninstall ;;
  --update)    UPDATE_MODE=true; install ;;
  -h|--help)
    echo "Usage: ./bin/install [--check | --update | --uninstall | -h] [--allow-worktree-root]"
    echo ""
    echo "  (no args)     Install/update harness skills and conduct script"
    echo "  --check       Check installation status"
    echo "  --update      Refresh symlinks + settings (skip deps + channel prompt)"
    echo "  --uninstall   Remove all symlinks"
    echo "  --allow-worktree-root"
    echo "                Bypass the refusal to install from a .worktrees/ checkout"
    echo "                (installs from a worktree normally repoint global symlinks"
    echo "                at a directory that is deleted at ship time)"
    echo "  -h, --help    Show this help"
    ;;
  *)           install ;;
esac
